model SearchIntelligenceProviderAccount {
  id              String    @id @default(cuid())
  businessId      String
  // provider: google_search_console | google_ads | google_business_profile
  //           | ahrefs | approved_serp_provider | manual_import
  provider        String
  accountId       String?
  accountName     String?
  // credentials_ref: name of secret/env reference — NEVER store raw secrets here
  credentialsRef  String?
  status          String    @default("disconnected") // disconnected | connected | error | pending
  lastConnectedAt DateTime?
  lastSyncAt      DateTime?
  errorMessage    String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  runs     SearchIntelligenceRun[]

  @@index([businessId])
  @@index([businessId, provider])
}

model SearchIntelligenceRun {
  id                    String    @id @default(cuid())
  businessId            String
  // run_type: weekly_search_intelligence | organic_serp_check | paid_ad_check | local_pack_check
  //   | maps_check | competitor_ad_check | competitor_organic_check | auction_insights_import
  //   | search_console_sync | google_ads_keyword_sync | google_ads_search_term_sync
  //   | ahrefs_keyword_sync | ahrefs_competitor_sync | manual_import
  runType               String
  dataSource            String? // provider id used
  providerAccountId     String?
  startedAt             DateTime?
  completedAt           DateTime?
  // status: queued | running | complete | partial | failed | cancelled
  status                String    @default("queued")
  keywordCount          Int       @default(0)
  locationCount         Int       @default(0)
  observationCount      Int       @default(0)
  competitorCount       Int       @default(0)
  // ── DataForSEO (and other provider) auditability fields ─────────────
  // First-class audit metadata so a run can be verified against the
  // provider's own check_url / task lookup. None of these are credentials.
  providerTaskId        String? // primary DataForSEO tasks[0].id
  providerTaskIdsJson   Json? // all task ids when a run issues multiple tasks
  checkUrl              String?   @db.Text // DataForSEO check_url for manual verification
  providerDatetime      String? // provider-reported capture datetime (as returned)
  providerStatusCode    Int? // provider status_code (e.g. 20000) or task status
  providerStatusMessage String?
  providerCost          Float? // provider-reported cost for the run
  locationCode          Int? // resolved DataForSEO location_code
  locationName          String? // resolved canonical location_name
  languageCode          String?
  device                String?
  serpItemTypesJson     Json? // distinct SERP item types seen + counts
  // raw_snapshot_ref: R2 object key for large raw provider payloads (never local paths)
  rawSnapshotRef        String?
  // isSandbox: true when produced by a DataForSEO sandbox / test request — keeps
  // test data clearly separable from real production observations.
  isSandbox             Boolean   @default(false)
  errorMessage          String?   @db.Text
  createdByTaskId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  business        Business                           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  providerAccount SearchIntelligenceProviderAccount? @relation(fields: [providerAccountId], references: [id], onDelete: SetNull)
  observations    SearchVisibilityObservation[]
  paidAds         PaidAdObservation[]
  recommendations SearchIntelligenceRecommendation[]
  manualNotes     SearchManualComparisonNote[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, runType])
  @@index([createdAt])
}

model SearchVisibilityObservation {
  id                String   @id @default(cuid())
  businessId        String
  runId             String?
  observedAt        DateTime @default(now())
  keywordId         String?
  locationId        String?
  searchEngine      String   @default("google")
  device            String   @default("desktop")
  // result_type: paid_ad | organic | local_pack | map_result | ai_overview
  //   | shopping | video | image | people_also_ask | unknown
  resultType        String   @default("organic")
  // position retains rank_absolute for backward compatibility; the two new
  // fields keep group vs absolute ranks distinct so the UI never shows an
  // absolute SERP position as if it were the organic rank.
  position          Int?
  rankGroup         Int? // rank within its own result-type block (organic rank)
  rankAbsolute      Int? // absolute position across all SERP elements
  source            String? // provider-reported item source (e.g. "Organic", domain source)
  rawItemJson       Json? // compact raw item summary for auditability
  pageNumber        Int?
  domain            String?
  url               String?
  title             String?
  snippet           String?  @db.Text
  // business_match_type: exact_domain | known_brand | known_location | possible_match | competitor | unknown
  businessMatchType String   @default("unknown")
  isSelf            Boolean  @default(false)
  competitorId      String?
  confidenceScore   Float    @default(0)
  dataSource        String? // provider / methodology — required for compliance
  rawSnapshotRef    String?
  isSandbox         Boolean  @default(false)
  createdAt         DateTime @default(now())

  business   Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  run        SearchIntelligenceRun?      @relation(fields: [runId], references: [id], onDelete: SetNull)
  keyword    SearchIntelligenceKeyword?  @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  location   SearchIntelligenceLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  competitor SearchCompetitor?           @relation(fields: [competitorId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, keywordId])
  @@index([businessId, locationId])
  @@index([businessId, resultType])
  @@index([runId])
  @@index([observedAt])
}

model SearchCompetitor {
  id               String   @id @default(cuid())
  businessId       String
  competitorName   String?
  domain           String?
  knownPagesJson   Json?
  serviceLinesJson Json?
  marketsJson      Json?
  source           String? // deep_research | observed | manual
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  // status: active | inactive | ignored | needs_review
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  business     Business                      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  observations SearchVisibilityObservation[]
  movements    CompetitorSearchMovement[]
  paidAds      PaidAdObservation[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, domain])
}

model CompetitorSearchMovement {
