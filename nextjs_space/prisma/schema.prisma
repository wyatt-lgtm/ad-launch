  name             String
  slug             String   @unique
  description      String   @default("")
  enabled          Boolean  @default(true)
  parentIndustryId String?
  sortOrder        Int      @default(0)
  // Matching aids: keywords / GBP categories that map to this industry
  matchKeywords    String[] @default([])
  gbpCategories    String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parentIndustry    Industry?                 @relation("IndustryHierarchy", fields: [parentIndustryId], references: [id], onDelete: SetNull)
  childIndustries   Industry[]                @relation("IndustryHierarchy")
  services          IndustryService[]
  businessOfferings BusinessServiceOffering[]

  @@index([enabled])
  @@index([parentIndustryId])
}

model IndustryService {
  id                           String   @id @default(cuid())
  industryId                   String
  name                         String
  slug                         String
  shortDescription             String   @default("")
  fullDescriptionTemplate      String   @default("") @db.Text
  customerProblem              String   @default("") @db.Text
  commonQuestions              Json     @default("[]") // string[] of FAQ questions
  commonObjections             Json     @default("[]") // string[]
  relatedServices              Json     @default("[]") // string[] of service slugs/names
