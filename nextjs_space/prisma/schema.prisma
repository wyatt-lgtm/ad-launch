  currentPosition  Int?
  previousPresence String?
  currentPresence  String?
  // movement_type: entered_market | left_market | gained_position | lost_position
  //   | gained_paid_presence | lost_paid_presence | gained_local_pack | lost_local_pack | no_change
  movementType     String    @default("no_change")
  changeSummary    String?   @db.Text
  confidenceScore  Float     @default(0)
  createdAt        DateTime  @default(now())

  business   Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  competitor SearchCompetitor            @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  keyword    SearchIntelligenceKeyword?  @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  location   SearchIntelligenceLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, competitorId])
  @@index([businessId, movementType])
}

model PaidAdObservation {
