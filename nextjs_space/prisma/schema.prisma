  city                String?
  county              String?
  state               String?
  country             String?  @default("US")
  latitude            Float?
  longitude           Float?
  radiusMiles         Float?
  // service_area_priority: low | medium | high | critical
  serviceAreaPriority String   @default("medium")
  marketLabel         String?
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business          Business                      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  observations      SearchVisibilityObservation[]
  paidAds           PaidAdObservation[]
  organicHistory    OrganicPositionHistory[]
  movements         CompetitorSearchMovement[]
  varianceSummaries SearchSerpVarianceSummary[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, locationType])
