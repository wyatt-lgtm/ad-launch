  maxKeywordsPerRun    Int      @default(100)
  maxLocationsPerRun   Int      @default(25)
  device               String   @default("desktop") // desktop | mobile | both
  includePaidAds       Boolean  @default(true)
  includeOrganic       Boolean  @default(true)
  includeLocalPack     Boolean  @default(true)
  includeCompetitors   Boolean  @default(true)
  includeAhrefs        Boolean  @default(false)
  includeGoogleAds     Boolean  @default(false)
  includeSearchConsole Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model SearchIntelligenceKeyword {
  id                      String   @id @default(cuid())
  businessId              String
  keyword                 String
  normalizedKeyword       String
  serviceLine             String?
  // market_orientation: b2c | b2b | mixed | unknown
  marketOrientation       String   @default("unknown")
  // keyword_intent: emergency | near_me | brand | competitor | price | comparison
  //   | problem | service | informational | transactional | b2b | b2c | local | national
  keywordIntent           String?
  funnelStage             String? // top_of_funnel | mid_funnel | bottom_funnel | converted
  // priority: low | medium | high | critical
  priority                String   @default("medium")
  source                  String? // deep_research | manual | bulk_import | google_ads | search_console | ahrefs
  matchTypeHint           String? // broad | phrase | exact
  preferredLandingPageUrl String?
  status                  String   @default("active") // active | paused | disabled
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  business          Business                      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  observations      SearchVisibilityObservation[]
  paidAds           PaidAdObservation[]
  organicHistory    OrganicPositionHistory[]
  movements         CompetitorSearchMovement[]
  varianceSummaries SearchSerpVarianceSummary[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, serviceLine])
  @@index([businessId, normalizedKeyword])
