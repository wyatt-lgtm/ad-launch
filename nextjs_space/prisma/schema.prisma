  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([agentType])
  @@index([intendedUse])
  @@index([createdAt])
  @@index([businessId, agentType])
}

model AssetContext {
  id              String  @id @default(cuid())
  businessAssetId String? @unique
  sharedAssetId   String? @unique

  // AI-generated descriptions
  agentDescription String? // concise description for AI agents
  humanDescription String? // optional human-edited description
  suggestedUses    String[] @default([]) // e.g. ["hero_image", "social_post", "ad_background"]
  restrictedUses   String[] @default([]) // e.g. ["not_for_ads", "internal_only"]

  // Visual / media analysis
  visibleElements String[] @default([]) // e.g. ["outdoor_patio", "smiling_staff", "logo_on_wall"]
  dominantColors  String[] @default([]) // hex codes or named colors
  mood            String? // e.g. "warm", "professional", "casual"
  style           String? // e.g. "lifestyle", "product_shot", "aerial"

  // Document / text analysis
  documentSummary     String? // summary for docs, PDFs, text assets
  keyPoints           String[] @default([]) // extracted key points
  restrictedClaims    String[] @default([]) // claims that must NOT be made (compliance)
  requiredDisclosures String[] @default([]) // must-include disclaimers

  // Audio / video analysis
  transcript        String? // for video/audio assets
  transcriptSummary String? // short summary of transcript

  // Quality / confidence
  confidenceScore Float? // 0.0 – 1.0, AI confidence in analysis
  qualityNotes    String[] @default([]) // e.g. ["low_resolution", "watermark_detected"]

  // Review status
  contextStatus        String    @default("needs_review") // needs_review, approved, rejected, stale
  aiGeneratedContext   Boolean   @default(true)
  humanReviewedContext Boolean   @default(false)
  reviewedByUserId     String?
  reviewedAt           DateTime?
  generationModel      String? // which LLM model was used
  generationError      String? // error message if generation failed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessAsset BusinessAsset? @relation(fields: [businessAssetId], references: [id], onDelete: Cascade)
  sharedAsset   SharedAsset?   @relation(fields: [sharedAssetId], references: [id], onDelete: Cascade)
  reviewedBy    User?          @relation("AssetContextReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([contextStatus])
  @@index([businessAssetId])
  @@index([sharedAssetId])
}

// ══════════════════════════════════════════════════════════════════════════════
// Industry Service Taxonomy & Business Service Offerings
// ══════════════════════════════════════════════════════════════════════════════

model Industry {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  description      String   @default("")
  enabled          Boolean  @default(true)
  parentIndustryId String?
  sortOrder        Int      @default(0)
  // Matching aids: keywords / GBP categories that map to this industry
  matchKeywords    String[] @default([])
  gbpCategories    String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parentIndustry    Industry?                 @relation("IndustryHierarchy", fields: [parentIndustryId], references: [id], onDelete: SetNull)
  childIndustries   Industry[]                @relation("IndustryHierarchy")
  services          IndustryService[]
  businessOfferings BusinessServiceOffering[]

  @@index([enabled])
  @@index([parentIndustryId])
}

model IndustryService {
  id                           String   @id @default(cuid())
  industryId                   String
  name                         String
  slug                         String
  shortDescription             String   @default("")
  fullDescriptionTemplate      String   @default("") @db.Text
  customerProblem              String   @default("") @db.Text
  commonQuestions              Json     @default("[]") // string[] of FAQ questions
  commonObjections             Json     @default("[]") // string[]
  relatedServices              Json     @default("[]") // string[] of service slugs/names
  recommendedPageTitle         String   @default("")
  recommendedMetaDescription   String   @default("")
  recommendedH1                String   @default("")
  recommendedSchemaType        String   @default("Service")
  explainerVideoTitle          String   @default("")
  explainerVideoBrief          String   @default("") @db.Text
  explainerVideoScriptTemplate String   @default("") @db.Text
  // Matching aids for Jim Bridger evidence detection
  matchKeywords                String[] @default([])
  conditional                  Boolean  @default(false) // "if applicable" services
  enabled                      Boolean  @default(true)
  sortOrder                    Int      @default(0)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  industry          Industry                  @relation(fields: [industryId], references: [id], onDelete: Cascade)
  businessOfferings BusinessServiceOffering[]

  @@unique([industryId, slug])
  @@index([industryId])
  @@index([enabled])
}

model BusinessServiceOffering {
  id                       String    @id @default(cuid())
  businessId               String
  industryServiceId        String? // null for fully custom services
  industryId               String? // denormalized for filtering
  customServiceName        String? // for custom services
  slug                     String
  // status: suggested | confirmed | rejected | hidden | needs_review
  status                   String    @default("suggested")
  // source: jim_bridger | website | owner_confirmed | ai_inferred | manual | imported
  source                   String    @default("jim_bridger")
  confidence               String    @default("low") // high | medium | low
  bridgerEvidenceJson      Json? // { evidenceSources: [{ type, url, snippet }] }
  ownerConfirmed           Boolean   @default(false)
  confirmedAt              DateTime?
  confirmedByUserId        String?
  // priority: primary | secondary | optional | do_not_promote
  priority                 String    @default("secondary")
  seoEnabled               Boolean   @default(true)
  // pageStatus: not_started | draft | needs_review | approved | published | archived
  pageStatus               String    @default("not_started")
  // videoStatus: not_started | brief_ready | script_ready | generated | approved | published
  videoStatus              String    @default("not_started")
  // Owner-editable overrides (fall back to industry service templates)
  overrideName             String?
  overrideShortDescription String?   @db.Text
  overrideFullDescription  String?   @db.Text
  // Generated artifacts
  generatedPageJson        Json? // generated service page content
  videoBriefJson           Json? // generated explainer video brief/script
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  industryService IndustryService? @relation(fields: [industryServiceId], references: [id], onDelete: SetNull)
  industry        Industry?        @relation(fields: [industryId], references: [id], onDelete: SetNull)
  confirmedBy     User?            @relation("ServiceConfirmer", fields: [confirmedByUserId], references: [id], onDelete: SetNull)

  @@unique([businessId, slug])
  @@index([businessId])
  @@index([businessId, status])
  @@index([industryServiceId])
}
