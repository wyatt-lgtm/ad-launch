# ── Ad Launch — Render Environment Variables ──────────────────────
# Copy this to Render's Environment tab (or use render.yaml sync).
# All values below are placeholders — fill in your actual secrets.

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── NextAuth ──────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret-here
AUTH_SECRET=same-as-nextauth-secret
NEXTAUTH_URL=https://connect.launchmarketing.com

# ── Tombstone Backend ─────────────────────────────────────────────
TOMBSTONE_API_URL=https://tombstone-api-xjc4.onrender.com
WEBSITE_RENDER_SERVICE_TOKEN=set-same-value-on-both-render-services

# ── Admin Auth (cron / internal endpoints) ────────────────────────
ADMIN_API_KEY=generate-a-strong-random-key

# ── API Keys ──────────────────────────────────────────────────────
# ARCHITECTURE RULE: Do NOT add OPENAI_API_KEY, ABACUSAI_API_KEY, or AWS_* keys here.
# All AI/model/image workflows route through Tombstone. Email uses EMAIL_PROVIDER.
GOOGLE_MAPS_API_KEY=your-google-maps-key
GHL_API_TOKEN=your-ghl-api-token
GHL_LOCATION_ID=your-ghl-location-id

# ── Email Provider ──────────────────────────────────────────────────
# Options: smtp | log (default: log = console-only, no real emails)
# For production, use "smtp" with a provider like Resend, SES, or SendGrid.
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
EMAIL_FROM=noreply@launchmarketing.com
