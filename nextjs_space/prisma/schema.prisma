model AgentAssetUsageLog {
  id                String   @id @default(cuid())
  businessId        String
  agentType         String // website, seo, social, video, community_engagement
  intendedUse       String // website, social, seo, video, community_engagement, ads, email
  workflowId        String?
  runId             String?
  retrievedAssetIds String[] @default([])
  usedAssetIds      String[] @default([])
  skippedAssetsJson Json? // [{assetId, reason}]
