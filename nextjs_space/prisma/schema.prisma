model AssetContext {
  id              String  @id @default(cuid())
  businessAssetId String? @unique
  sharedAssetId   String? @unique

  // AI-generated descriptions
  agentDescription String? // concise description for AI agents
  humanDescription String? // optional human-edited description
  suggestedUses    String[] @default([]) // e.g. ["hero_image", "social_post", "ad_background"]
  restrictedUses   String[] @default([]) // e.g. ["not_for_ads", "internal_only"]

  // Visual / media analysis
  visibleElements String[] @default([]) // e.g. ["outdoor_patio", "smiling_staff", "logo_on_wall"]
  dominantColors  String[] @default([]) // hex codes or named colors
  mood            String? // e.g. "warm", "professional", "casual"
  style           String? // e.g. "lifestyle", "product_shot", "aerial"

  // Document / text analysis
  documentSummary     String? // summary for docs, PDFs, text assets
  keyPoints           String[] @default([]) // extracted key points
  restrictedClaims    String[] @default([]) // claims that must NOT be made (compliance)
  requiredDisclosures String[] @default([]) // must-include disclaimers

  // Audio / video analysis
  transcript        String? // for video/audio assets
  transcriptSummary String? // short summary of transcript

  // Quality / confidence
  confidenceScore Float? // 0.0 – 1.0, AI confidence in analysis
  qualityNotes    String[] @default([]) // e.g. ["low_resolution", "watermark_detected"]

  // Review status
  contextStatus        String    @default("needs_review") // needs_review, approved, rejected, stale
  aiGeneratedContext   Boolean   @default(true)
  humanReviewedContext Boolean   @default(false)
  reviewedByUserId     String?
  reviewedAt           DateTime?
  generationModel      String? // which LLM model was used
  generationError      String? // error message if generation failed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessAsset BusinessAsset? @relation(fields: [businessAssetId], references: [id], onDelete: Cascade)
  sharedAsset   SharedAsset?   @relation(fields: [sharedAssetId], references: [id], onDelete: Cascade)
  reviewedBy    User?          @relation("AssetContextReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([contextStatus])
  @@index([businessAssetId])
  @@index([sharedAssetId])
}

// ══════════════════════════════════════════════════════════════════════════════
// Industry Service Taxonomy & Business Service Offerings
// ══════════════════════════════════════════════════════════════════════════════

model Industry {
