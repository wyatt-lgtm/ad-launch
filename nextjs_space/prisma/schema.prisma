  @@unique([businessId, sharedAssetId])
  @@index([businessId])
  @@index([sharedAssetId])
  @@index([status])
}

model BusinessSharedAssetPackGrant {
  id              String    @id @default(cuid())
  businessId      String
  packId          String
  grantedByUserId String?
  status          String    @default("pending") // pending, granted, rejected, expired, revoked
