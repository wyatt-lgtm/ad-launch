  @@unique([businessId, slug])
  @@index([businessId])
  @@index([businessId, status])
  @@index([industryServiceId])
}

// ─────────────────────────────────────────────────────────────────────
// Tracking Pixels & Funnel Event Tracking (Insights → Tracking Pixels)
// Business-scoped tracking config for websites, landing pages, thank-you
// pages, ads, social and retargeting pixels. Postgres only. Never leak
// pixels across businesses; custom scripts are stored, never executed in UI.
// ─────────────────────────────────────────────────────────────────────

model TrackingPixel {
  id             String  @id @default(cuid())
  businessId     String
  name           String
  // platform: meta | facebook | google_ads | ga4 | google_tag | google_tag_manager
  //           | tiktok | linkedin | bing | microsoft_ads | pinterest | x | twitter | choozle | custom
  platform       String
  // pixel_type: base_pixel | remarketing_pixel | conversion_pixel | analytics_tag
  //             | tag_manager | custom_script | custom_html | event_snippet
  pixelType      String  @default("base_pixel")
  // tracking_method: browser | server | hybrid
  trackingMethod String  @default("browser")
  // Generic external pixel/tag id
  pixelId        String?
  // Stored, NEVER executed in the admin UI
  scriptSnippet  String? @db.Text
  // placement: head | body_start | body_end | event_only
  placement      String  @default("head")
  // scope: all_pages | selected_pages | landing_pages | social_landing_pages | blog_pages
  //        | service_pages | thank_you_pages | checkout_or_conversion_pages | custom_rules
  scope          String  @default("all_pages")
  // status: active | inactive | draft | error | needs_verification | archived
  status         String  @default("draft")

  // ── Consent / privacy ───────────────────────────────────────────
  consentRequired      Boolean @default(false)
  // consent_category: essential | analytics | advertising | remarketing | conversion_tracking
  consentCategory      String  @default("analytics")
  firesBeforeConsent   Boolean @default(false)
  regionRulesJson      Json?
  cookieBannerRequired Boolean @default(false)

  // ── Verification ────────────────────────────────────────────────
  // verification_status: unverified | pending | verified | failed
  verificationStatus String    @default("unverified")
  verifiedAt         DateTime?
  lastVerifiedUrl    String?
  lastSeenAt         DateTime?
  lastEventSeenAt    DateTime?
  lastError          String?   @db.Text
  testModeEnabled    Boolean   @default(false)

  // ── Platform-specific ids ───────────────────────────────────────
  // GA4 / Analytics
  ga4MeasurementId           String?
  analyticsStreamId          String?
  analyticsPropertyId        String?
  defaultPageViewEnabled     Boolean @default(true)
  enhancedMeasurementEnabled Boolean @default(true)
  // Google Tag / Google Ads / GTM
  googleTagId                String?
  googleAdsConversionId      String?
  googleAdsConversionLabel   String?
  gtmContainerId             String?
  // Meta / Facebook
  metaPixelId                String?
  metaDatasetId              String?
  metaConversionsApiEnabled  Boolean @default(false)
  // TikTok
  tiktokPixelId              String?
  tiktokEventsApiEnabled     Boolean @default(false)
  // LinkedIn
  linkedinPartnerId          String?
  linkedinConversionId       String?
  // Bing / Microsoft Ads
  bingUetTagId               String?
  // Choozle
  choozleAdvertiserId        String?
  choozlePixelId             String?
  choozleConversionId        String?
  // Server-side tracking
  serverEventEnabled         Boolean @default(false)
  deduplicationKeyStrategy   String?
  externalEventIdField       String?
  hashedEmailEnabled         Boolean @default(false)
  hashedPhoneEnabled         Boolean @default(false)
  enhancedConversionsEnabled Boolean @default(false)

  // ── Guided setup wizard ─────────────────────────────────────────
  // setupStatus: needs_setup | needs_customer_action | waiting_for_pixel_id
  //              | waiting_for_script | ready_to_install | installed | verified
  //              | failed_verification | inactive
  manualSetupRequired   Boolean @default(false)
  setupStatus           String?
  setupInstructionsJson Json?
  platformSetupUrl      String?
  // installation_target: tombstone_generated_site | ghl_funnel | ghl_website
  //                      | wordpress | gtm | manual | unknown
  installationTarget    String? @default("unknown")
  installStatus         String?
  installNotes          String? @db.Text

  createdByUserId String?
  updatedByUserId String?
  version         Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  archivedAt      DateTime?

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  events   TrackingEvent[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, platform])
  @@index([businessId, scope])
}

model TrackingEvent {
  id                       String   @id @default(cuid())
  businessId               String
  pixelId                  String?
  eventName                String // page_view | landing_page_view | thank_you_page_view | form_submit | generate_lead | lead | ...
  platformEventName        String? // e.g. PageView, Lead, generate_lead
  // event_type: page_view | lead | conversion | click | form | phone | email | purchase | custom
  eventType                String   @default("custom")
  // trigger_type: page_load | url_match | form_submit | button_click | phone_link_click
  //               | email_link_click | thank_you_page_load | custom_js | server_event | webhook_event
  triggerType              String   @default("page_load")
  // page_scope mirrors pixel scope values
  pageScope                String   @default("all_pages")
  pageMatchRulesJson       Json?
  selectorRule             String?
  urlRule                  String?
  valueSource              String?
  conversionValue          Float?
  currency                 String?  @default("USD")
  leadStatusMapping        String?
  deduplicationEnabled     Boolean  @default(false)
  deduplicationKeyStrategy String?
  requiresConsent          Boolean  @default(false)
  consentCategory          String   @default("analytics")
  // status: active | inactive | draft | archived
  status                   String   @default("active")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  pixel    TrackingPixel? @relation(fields: [pixelId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, status])
  @@index([pixelId])
  @@index([businessId, eventName])
}

model TrackingAudience {
  id                 String    @id @default(cuid())
  businessId         String
  audienceName       String
  platform           String    @default("custom")
  // audience_type: website_visitors | landing_page_visitors | thank_you_page_visitors
  //                | converted_leads | non_converting_visitors | high_intent_visitors
  //                | bottom_funnel | exclusion | lookalike_seed | custom
  audienceType       String    @default("custom")
  sourceEvent        String?
  includeRulesJson   Json?
  excludeRulesJson   Json?
  retentionDays      Int       @default(30)
  // funnel_stage: top_of_funnel | mid_funnel | bottom_funnel | converted | customer | reactivation
  funnelStage        String?
  // status: active | inactive | draft | archived
  status             String    @default("active")
  externalAudienceId String?
  lastSyncedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, audienceType])
}

model TrackingEventRoute {
  id              String   @id @default(cuid())
  businessId      String
  // page_type: website_page | landing_page | social_landing_page | thank_you_page
  //            | service_page | blog_page | city_page | county_page | checkout_page | custom
  pageType        String
  pageUrlPattern  String?
  eventName       String
  platformsJson   Json?
  // fires_on: page_load | url_match | form_submit | button_click | phone_link_click | ...
  firesOn         String   @default("page_load")
  requiresConsent Boolean  @default(false)
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, pageType])
}

model TrackingPixelAuditEvent {
  id              String   @id @default(cuid())
  businessId      String
  pixelId         String?
  eventId         String?
  // action: created | updated | disabled | enabled | archived | verified | failed_verification
  //         | injected_on_page | event_fired | test_event_sent | error_detected
  action          String
  detailsJson     Json?
  createdByUserId String?
  createdAt       DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, pixelId])
  @@index([action])
  @@index([createdAt])
}

// ════════════════════════════════════════════════════════════════════
// Three-tier Jim Bridger research + Ongoing Search Intelligence
// All models are business-scoped (business_id) to prevent cross-business
// leakage. Research depth is durable so light research never overwrites
// deep research. No Tombstone task lifecycle logic lives here.
// ════════════════════════════════════════════════════════════════════

// Durable, business-scoped research intelligence layer. One current row
// per (businessId, researchDepth); refresh runs append history.
model BusinessResearch {
  id               String    @id @default(cuid())
  businessId       String
  // research_depth: light | deep | ongoing | refresh
  researchDepth    String    @default("light")
  // output_type: initial_business_research | deep_business_research | ongoing_search_intelligence
  outputType       String
  // research_status: pending | queued | running | complete | needs_review | failed
  researchStatus   String    @default("pending")
  isCurrent        Boolean   @default(true)
  sourceUrl        String?
  previewPackageId String?
  analysisId       String?
  workflowId       String?
  createdByAgent   String? // e.g. jim_bridger
  createdTaskId    String?
  // Structured research output (deep_business_profile, brand_voice_profile,
  // competitor_summary, positioning_profile, audience_segments, service_line_map,
  // seo_opportunities, tracking_pixel_discoveries, content_strategy, claims, etc.)
  profileJson      Json?
  summary          String?   @db.Text
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, researchDepth])
  @@index([businessId, researchDepth, isCurrent])
  @@index([analysisId])
}

// Tracking pixels/tags discovered on the business website during Deep Research.
// Discovery layer — stored before being treated as approved config.
model TrackingPixelDiscovery {
  id                     String   @id @default(cuid())
  businessId             String
  sourceUrl              String? // root website url scanned
  pageUrl                String? // specific page where it was detected
  // platform mirrors TrackingPixel platform values
  platform               String
  // pixel_type: base_pixel | analytics_tag | tag_manager | conversion_pixel | remarketing_pixel | custom_script
  pixelType              String   @default("base_pixel")
  detectedId             String?
  detectedScriptUrl      String?
  detectedEventNamesJson Json?
  placementDetected      String? // head | body_start | body_end | gtm | unknown
  confidenceScore        Float    @default(0)
  detectionMethod        String? // script_src_match | inline_snippet_match | gtm_container | network_request | meta_tag
  // status: detected_unmatched | matched_existing_config | duplicate_possible
  //         | missing_from_config | needs_review | ignored | configured_but_not_found
  status                 String   @default("detected_unmatched")
  matchedTrackingPixelId String?
  createdTaskId          String?
  createdByAgent         String?
  firstSeenAt            DateTime @default(now())
  lastSeenAt             DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, platform])
  @@index([matchedTrackingPixelId])
}

model SearchIntelligenceSettings {
  id                   String   @id @default(cuid())
