  hasAudio                    Boolean? // for video files
  hasTransparency             Boolean? // for images
  wordCount                   Int? // for documents
  extractedTextPreview        String? // first ~200 chars of document text
  intendedUses                String[] @default([]) // website, social, video, ads, seo, email, print, internal
