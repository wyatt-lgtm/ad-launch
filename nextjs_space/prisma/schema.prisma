generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/ad_launch/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  password          String
  confirmed         Boolean              @default(false)
  confirmationToken String?              @unique
  freeAdsUsed       Int                  @default(0)
  paidAdsCount      Int                  @default(0)
  role              String               @default("user")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  analyses          Analysis[]
  businesses        Business[]
  passwordResets    PasswordResetToken[]
  socialAccounts    SocialAccount[]
  socialPosts       SocialPost[]
  feedPreferences   UserFeedPreference[]
  scoutReports      ScoutReport[]
  postPackages      PostPackage[]
}

model Business {
  id                String                   @id @default(cuid())
  userId            String
  websiteUrl        String
  businessName      String?
  businessAddr      String?
  businessCity      String?
  businessState     String?
  businessZip       String?
  businessPhone     String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  contentSourceMode String                   @default("local_plus_interests")
  analyses          Analysis[]
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedPreferences   BusinessFeedPreference[]
  socialPosts       SocialPost[]
  scoutEmailSettings ScoutEmailSettings?
  scoutEmailHistory  ScoutEmailHistory[]
  scoutReports       ScoutReport[]
  postPackages       PostPackage[]
  creditAccount      CreditAccount?

  @@unique([userId, websiteUrl])
  @@index([userId])
}

model ScoutEmailSettings {
  id              String   @id @default(cuid())
  businessId      String   @unique
  enabled         Boolean  @default(false)
  recipientEmail  String   @default("")
  sendTimeUtc     String   @default("14:00")
  includeLocal    Boolean  @default(true)
  includeIndustry Boolean  @default(true)
  includeNational Boolean  @default(true)
  maxStories      Int      @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([enabled])
}

model ScoutEmailHistory {
  id          String   @id @default(cuid())
  businessId  String
  storyTitle  String
  storyLink   String   @default("")
  storySource String   @default("")
  sourceType  String   @default("local")
  sentAt      DateTime @default(now())
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, sentAt])
  @@index([businessId, storyTitle])
}

model BusinessFeedPreference {
  id         String   @id @default(cuid())
  businessId String
  industry   String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, industry])
  @@index([businessId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model UserFeedPreference {
  id        String   @id @default(cuid())
  userId    String
  industry  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, industry])
  @@index([userId])
}

model Analysis {
  id              String       @id @default(cuid())
  userId          String?
  websiteUrl      String
  missionId       String?
  status          String       @default("pending")
  results         Json?
  seoData         Json?
  postingPlan     Json?
  businessName    String?
  businessAddr    String?
  businessCity    String?
  businessState   String?
  businessZip     String?
  businessPhone   String?
  geoConfirmed    Boolean      @default(false)
  geoSource       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  socialMissionId String?
  businessId      String?
  ads             Ad[]
  business        Business?    @relation(fields: [businessId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])
  socialPosts     SocialPost[]

  @@index([userId])
  @@index([businessId])
  @@index([missionId])
  @@index([socialMissionId])
  @@index([businessZip])
  @@index([businessState])
}

model Ad {
  id             String   @id @default(cuid())
  analysisId     String
  imageUrl       String?
  watermarkedUrl String?
  caption        String?
  headline       String?
  watermarked    Boolean  @default(true)
  createdAt      DateTime @default(now())
  lane           String?
  analysis       Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

model ContentPolicy {
  id          String   @id @default(cuid())
  category    String   @unique
  action      String
  label       String?
  description String?
  keywords    String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GeoState {
  id        String      @id @default(cuid())
  code      String      @unique
  name      String
  fipsCode  String?     @unique
  createdAt DateTime    @default(now())
  counties  GeoCounty[]
}

model GeoCounty {
  id        String    @id @default(cuid())
  name      String
  fipsCode  String?   @unique
  stateId   String
  createdAt DateTime  @default(now())
  cities    GeoCity[]
  state     GeoState  @relation(fields: [stateId], references: [id])

  @@index([stateId])
  @@index([name, stateId])
}

model GeoCity {
  id         String       @id @default(cuid())
  name       String
  countyId   String
  latitude   Float?
  longitude  Float?
  population Int?
  createdAt  DateTime     @default(now())
  county     GeoCounty    @relation(fields: [countyId], references: [id])
  cityZips   GeoCityZip[]

  @@index([countyId])
  @@index([name, countyId])
}

model GeoZip {
  id        String       @id @default(cuid())
  code      String       @unique
  latitude  Float?
  longitude Float?
  createdAt DateTime     @default(now())
  feedGeos  FeedGeo[]
  cityZips  GeoCityZip[]

  @@index([code])
}

model GeoCityZip {
  id        String  @id @default(cuid())
  cityId    String
  zipId     String
  isPrimary Boolean @default(false)
  city      GeoCity @relation(fields: [cityId], references: [id])
  zip       GeoZip  @relation(fields: [zipId], references: [id])

  @@unique([cityId, zipId])
  @@index([zipId])
  @@index([cityId])
}

model RssFeed {
  id                String      @id @default(cuid())
  url               String      @unique
  title             String?
  description       String?
  siteUrl           String?
  language          String?
  sourceType        String      @default("unknown")
  sourceQuality     String      @default("unverified")
  status            String      @default("pending")
  freshnessScore    Float?
  qualityScore      Float?
  lastFetchedAt     DateTime?
  lastItemDate      DateTime?
  fetchErrorCount   Int         @default(0)
  consecutiveErrors Int         @default(0)
  avgItemsPerWeek   Float?
  contentHash       String?
  canonicalUrl      String?
  discoveredBy      String?
  discoveryMethod   String?
  feedFormat        String?
  pilotState        String?
  discoveredAt      DateTime    @default(now())
  verifiedBy        String?
  verifiedAt        DateTime?
  geoScope          String      @default("local")
  lastAgentRun      String?
  lastAgentRunAt    DateTime?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  contentTags       String[]    @default([])
  industry          String?
  localizable       Boolean     @default(false)
  updateFrequency   String?
  feedAudits        FeedAudit[]
  feedGeos          FeedGeo[]
  items             RssItem[]

  @@index([status])
  @@index([sourceType])
  @@index([sourceQuality])
  @@index([freshnessScore])
  @@index([lastItemDate])
  @@index([geoScope])
  @@index([geoScope, status])
  @@index([industry])
}

model FeedGeo {
  id           String   @id @default(cuid())
  feedId       String
  zipId        String
  coverageType String
  confidence   Float    @default(0.5)
  source       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  feed         RssFeed  @relation(fields: [feedId], references: [id], onDelete: Cascade)
  zip          GeoZip   @relation(fields: [zipId], references: [id])

  @@unique([feedId, zipId])
  @@index([zipId])
  @@index([feedId])
  @@index([coverageType])
  @@index([confidence])
}

model RssItem {
  id              String      @id @default(cuid())
  feedId          String
  guid            String
  title           String?
  description     String?
  link            String?
  pubDate         DateTime?
  author          String?
  imageUrl        String?
  contentHash     String?
  categories      String[]    @default([])
  filterStatus    String      @default("pending")
  filterReason    String?
  blockedCategory String?
  relevanceScore  Float?
  usedInPost      Boolean     @default(false)
  usedAt          DateTime?
  postReference   String?
  fetchedAt       DateTime    @default(now())
  createdAt       DateTime    @default(now())
  itemAudits      ItemAudit[]
  feed            RssFeed     @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@unique([feedId, guid])
  @@index([feedId])
  @@index([pubDate])
  @@index([filterStatus])
  @@index([contentHash])
  @@index([usedInPost])
}

model FeedAudit {
  id          String   @id @default(cuid())
  feedId      String
  action      String
  oldValue    String?
  newValue    String?
  reason      String?
  performedBy String?
  createdAt   DateTime @default(now())
  feed        RssFeed  @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@index([feedId])
  @@index([createdAt])
  @@index([action])
}

model ItemAudit {
  id          String   @id @default(cuid())
  itemId      String
  action      String
  category    String?
  confidence  Float?
  reason      String?
  performedBy String?
  createdAt   DateTime @default(now())
  item        RssItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([createdAt])
  @@index([action])
}

model ScoutReport {
  id           String       @id @default(cuid())
  businessId   String
  userId       String
  status       String       @default("sent") // sent, expired
  storiesCount Int          @default(0)
  sentAt       DateTime     @default(now())
  expiresAt    DateTime
  createdAt    DateTime     @default(now())
  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories      ScoutStory[]

  @@index([businessId])
  @@index([userId])
  @@index([sentAt])
}

model ScoutStory {
  id              String      @id @default(cuid())
  scoutReportId   String
  title           String
  source          String
  sourceUrl       String      @default("")
  sourceType      String      @default("local") // local, industry, national
  pubDate         String      @default("")
  summary         String      @default("")
  relevance       String      @default("")
  suggestedAngle  String      @default("")
  createdAt       DateTime    @default(now())
  scoutReport     ScoutReport @relation(fields: [scoutReportId], references: [id], onDelete: Cascade)
  postPackages    PostPackage[]

  @@index([scoutReportId])
}

model MagicToken {
  id            String   @id @default(cuid())
  token         String   @unique
  userId        String
  businessId    String
  scoutReportId String?
  storyId       String?
  action        String   // create_post, review_stories, review_package
  nonce         String   @unique
  used          Boolean  @default(false)
  usedAt        DateTime?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@index([nonce])
}

model PostPackage {
  id              String      @id @default(cuid())
  userId          String
  businessId      String
  storyId         String?
  scoutReportId   String?
  source          String      @default("daily_scout_email") // daily_scout_email, app_review
  workflowId      String?
  status          String      @default("generating") // generating, ready, downloaded, draft, rejected, posted
  postCopy        String?     @default("")
  headline        String?     @default("")
  cta             String?     @default("")
  hashtags        String[]    @default([])
  imageUrl        String?     @default("")
  storyTitle      String      @default("")
  storySource     String      @default("")
  storyUrl        String      @default("")
  storySummary    String      @default("")
  suggestedAngle  String      @default("")
  completedAt     DateTime?
  completionEmailSent Boolean  @default(false)
  // Credit tracking
  creditChargedAt     DateTime?
  creditCost          Int?         @default(0)
  creditTransactionId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  story           ScoutStory? @relation(fields: [storyId], references: [id])

  @@index([userId])
  @@index([businessId])
  @@index([workflowId])
  @@index([status])
  @@index([completionEmailSent, status])
}

// ─── Credit System ───────────────────────────────────────────────

model CreditAccount {
  id                      String   @id @default(cuid())
  businessId              String   @unique
  creditBalance           Int      @default(0)
  monthlyCreditAllowance  Int      @default(6)
  creditsRenewAt          DateTime?
  creditPlanName          String?  @default("starter")
  creditStatus            String   @default("active") // active, suspended, cancelled
  // Stripe-ready placeholders
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  stripePriceId           String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  business                Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions            CreditTransaction[]

  @@index([creditStatus])
}

model CreditTransaction {
  id              String   @id @default(cuid())
  creditAccountId String
  businessId      String
  userId          String?
  postPackageId   String?
  transactionType String   // monthly_grant, admin_grant, image_post_charge, video_upgrade_charge, recharge_grant, refund, adjustment, failed_generation_refund, recharge_pending
  amount          Int      // positive = credit added, negative = credit spent
  balanceAfter    Int
  reason          String   @default("")
  idempotencyKey  String?  @unique
  // Stripe-ready placeholders
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  rechargePackId          String?
  metadata        Json?
  createdAt       DateTime @default(now())
  creditAccount   CreditAccount @relation(fields: [creditAccountId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
  @@index([postPackageId])
  @@index([transactionType])
  @@index([createdAt])
}

model InternalCostLedger {
  id                    String   @id @default(cuid())
  businessId            String?
  userId                String?
  postPackageId         String?
  workflowId            String?
  taskId                String?
  provider              String?  // openai, fal, render, cloudflare_r2, abacus
  costType              String   // llm, image_generation, video_generation, render_runtime, r2_storage, r2_bandwidth, email, other
  estimatedCostUsd      Decimal  @default(0) @db.Decimal(10, 6)
  inputTokens           Int?
  outputTokens          Int?
  imageCount            Int?
  videoSeconds          Int?
  renderRuntimeSeconds  Int?
  retryCount            Int?
  metadata              Json?
  createdAt             DateTime @default(now())

  @@index([businessId])
  @@index([postPackageId])
  @@index([workflowId])
  @@index([costType])
  @@index([createdAt])
}

model SocialAccount {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  handle      String
  profileUrl  String?
  displayName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
  @@index([platform])
}

model SocialPost {
  id              String    @id @default(cuid())
  userId          String
  analysisId      String?
  caption         String
  hashtags        String[]  @default([])
  imageUrl        String?
  imagePrompt     String?
  rssItemId       String?
  rssItemTitle    String?
  rssItemLink     String?
  sourceType      String?
  newsAngle       String?
  platforms       String[]  @default([])
  postType        String    @default("general")
  status          String    @default("draft")
  scheduledFor    DateTime?
  publishedAt     DateTime?
  rejectedAt      DateTime?
  rejectReason    String?
  tradeAreaZip    String?
  briefScore      Float?
  patternType     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tombstoneTaskId String?
  businessId      String?
  analysis        Analysis? @relation(fields: [analysisId], references: [id])
  business        Business? @relation(fields: [businessId], references: [id])
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([analysisId])
  @@index([businessId])
  @@index([scheduledFor])
  @@index([createdAt])
}
