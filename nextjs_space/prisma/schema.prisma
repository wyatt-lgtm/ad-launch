generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/ad_launch/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  password          String
  confirmed         Boolean              @default(false)
  confirmationToken String?              @unique
  freeAdsUsed       Int                  @default(0)
  paidAdsCount      Int                  @default(0)
  role              String               @default("user")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  analyses          Analysis[]
  businesses        Business[]
  passwordResets    PasswordResetToken[]
  socialAccounts    SocialAccount[]
  socialPosts       SocialPost[]
  feedPreferences   UserFeedPreference[]
  scoutReports      ScoutReport[]
  postPackages      PostPackage[]
  generationRuns    GenerationRun[]
  uploadedAssets    BusinessAsset[]
  siteFeedback      SiteFeedback[]   @relation("SiteFeedbackUser")
  scheduledPosts    ScheduledPost[]  @relation("ScheduledPostUser")
  approvedPosts     ScheduledPost[]  @relation("ScheduledPostApprover")
}

model Business {
  id                String                   @id @default(cuid())
  userId            String?
  websiteUrl        String
  businessName      String?
  businessAddr      String?
  businessCity      String?
  businessState     String?
  businessZip       String?
  businessPhone     String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  contentSourceMode String                   @default("local_plus_interests")
  // Canonical Tombstone OS business identity, persisted for reuse across analyses.
  tombstoneBusinessId   Int?
  tombstoneBusinessUuid String?
  // Token linking anonymous sessions to their Business record before registration.
  anonymousToken    String?                  @unique
  analyses          Analysis[]
  user              User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedPreferences   BusinessFeedPreference[]
  socialPosts       SocialPost[]
  scoutEmailSettings ScoutEmailSettings?
  scoutEmailHistory  ScoutEmailHistory[]
  scoutReports       ScoutReport[]
  postPackages       PostPackage[]
  creditAccount      CreditAccount?
  contentProfile     BusinessContentProfile?
  savedAnalysis       Json?
  analysisRefreshedAt DateTime?
  hasMultipleLocations Boolean                @default(false)
  assets              BusinessAsset[]
  locations           BusinessLocation[]
  publishSettings     PublishSettings?
  socialConnections   SocialConnection[]
  scheduledPosts      ScheduledPost[]

  // ── Service area & website build mode ──────────────────────────────
  serviceAreaMode       String?          // local | regional | national | multi_location
  isNationwide          Boolean          @default(false)
  hqCity                String?
  hqState               String?
  primaryMarketCity     String?
  primaryMarketState    String?
  targetMarkets         String[]         @default([])
  websiteBuildMode      String           @default("multi_page_seo") // single_page | multi_page_seo
  forbiddenBrandTerms   String[]         @default([])

  // ── Default social landing page ─────────────────────────────────
  defaultSocialLandingPageUrl     String?
  defaultSocialLandingPageEnabled Boolean  @default(false)
  defaultSocialCtaText            String   @default("Learn more here:")

  // ── GoHighLevel tenant provisioning ─────────────────────────────
  ghlLocationId         String?          // GHL location ID returned by provisioning API
  ghlSubtenantId        String?          // GHL sub-account / subtenant ID
  ghlProvisioningStatus String?          // pending | provisioned | failed
  ghlProvisionedAt      DateTime?
  ghlProvisioningError  String?
  ghlApiToken           String?          // Per-business GHL API token (for linked_existing accounts)
  ghlConnectionType     String?          // created_new | linked_existing
  ghlLinkedAt           DateTime?
  ghlLinkNotes          String?

  // ── Default GHL Social Planner account ──────────────────────────
  defaultGhlSocialAccountId   String?    // Full GHL Social Planner account ID
  defaultGhlSocialAccountName String?    // Display name (e.g. "Blazing Hog Wireless Internet")
  defaultGhlSocialPlatform    String?    // facebook | tiktok | instagram | etc.
  defaultGhlSocialOriginId    String?    // GHL platform-specific origin ID

  @@unique([userId, websiteUrl])
  @@index([userId])
}

model BusinessLocation {
  id              String   @id @default(cuid())
  businessId      String
  locationNumber  Int
  locationName    String?
  address1        String?
  address2        String?
  city            String?
  state           String?
  postalCode      String?
  county          String?
  country         String   @default("US")
  latitude        Float?
  longitude       Float?
  placeId         String?
  source          String?  // google_places, user_added, existing_business, imported
  isPrimary       Boolean  @default(false)
  isConfirmed     Boolean  @default(true)
  pageSlug        String?
  phone           String?
  googleMapsUrl   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, locationNumber])
  @@unique([businessId, placeId])
  @@index([businessId])
}

model BusinessContentProfile {
  id                  String   @id @default(cuid())
  businessId          String   @unique
  contentPillars      Json     @default("[]")
  allowedAdjacentTopics Json   @default("[]")
  seasonalTopicMap    Json     @default("{}")
  faqTopics           Json     @default("[]")
  audienceSegments    Json     @default("[]")
  brandVoiceSummary   String   @default("")
  restrictedTopics    Json     @default("[]")
  evergreenTopics     Json     @default("[]")
  industry            String   @default("")
  lastEnrichedAt      DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ScoutEmailSettings {
  id              String   @id @default(cuid())
  businessId      String   @unique
  enabled         Boolean  @default(false)
  recipientEmail  String   @default("")
  sendTimeUtc     String   @default("14:00")
  includeLocal    Boolean  @default(true)
  includeIndustry Boolean  @default(true)
  includeNational Boolean  @default(true)
  maxStories      Int      @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([enabled])
}

model ScoutEmailHistory {
  id          String   @id @default(cuid())
  businessId  String
  storyTitle  String
  storyLink   String   @default("")
  storySource String   @default("")
  sourceType  String   @default("local")
  sentAt      DateTime @default(now())
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, sentAt])
  @@index([businessId, storyTitle])
}

model BusinessFeedPreference {
  id         String   @id @default(cuid())
  businessId String
  industry   String
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, industry])
  @@index([businessId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model UserFeedPreference {
  id        String   @id @default(cuid())
  userId    String
  industry  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, industry])
  @@index([userId])
}

model Analysis {
  id              String       @id @default(cuid())
  userId          String?
  websiteUrl      String
  missionId       String?
  status          String       @default("pending")
  results         Json?
  seoData         Json?
  postingPlan     Json?
  businessName    String?
  businessAddr    String?
  businessCity    String?
  businessState   String?
  businessZip     String?
  businessPhone   String?
  geoConfirmed    Boolean      @default(false)
  geoSource       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  socialMissionId String?
  businessId      String?
  // Canonical Tombstone OS business identity (created via POST /businesses/provisional).
  // tombstoneBusinessId is the integer key the Tombstone /commands gate requires for
  // customer-facing content; tombstoneBusinessUuid is the public token held until signup.
  tombstoneBusinessId   Int?
  tombstoneBusinessUuid String?
  // Token linking anonymous sessions to their Analysis record before registration.
  anonymousToken    String?                  @unique
  ads             Ad[]
  business        Business?    @relation(fields: [businessId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])
  socialPosts     SocialPost[]

  @@index([userId])
  @@index([businessId])
  @@index([missionId])
  @@index([socialMissionId])
  @@index([businessZip])
  @@index([businessState])
}

model Ad {
  id             String   @id @default(cuid())
  analysisId     String
  imageUrl       String?
  watermarkedUrl String?
  caption        String?
  headline       String?
  watermarked    Boolean  @default(true)
  createdAt      DateTime @default(now())
  lane           String?
  analysis       Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

model ContentPolicy {
  id          String   @id @default(cuid())
  category    String   @unique
  action      String
  label       String?
  description String?
  keywords    String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GeoState {
  id        String      @id @default(cuid())
  code      String      @unique
  name      String
  fipsCode  String?     @unique
  createdAt DateTime    @default(now())
  counties  GeoCounty[]
}

model GeoCounty {
  id        String    @id @default(cuid())
  name      String
  fipsCode  String?   @unique
  stateId   String
  createdAt DateTime  @default(now())
  cities    GeoCity[]
  state     GeoState  @relation(fields: [stateId], references: [id])

  @@index([stateId])
  @@index([name, stateId])
}

model GeoCity {
  id         String       @id @default(cuid())
  name       String
  countyId   String
  latitude   Float?
  longitude  Float?
  population Int?
  createdAt  DateTime     @default(now())
  county     GeoCounty    @relation(fields: [countyId], references: [id])
  cityZips   GeoCityZip[]

  @@index([countyId])
  @@index([name, countyId])
}

model GeoZip {
  id        String       @id @default(cuid())
  code      String       @unique
  latitude  Float?
  longitude Float?
  createdAt DateTime     @default(now())
  feedGeos  FeedGeo[]
  cityZips  GeoCityZip[]

  @@index([code])
}

model GeoCityZip {
  id        String  @id @default(cuid())
  cityId    String
  zipId     String
  isPrimary Boolean @default(false)
  city      GeoCity @relation(fields: [cityId], references: [id])
  zip       GeoZip  @relation(fields: [zipId], references: [id])

  @@unique([cityId, zipId])
  @@index([zipId])
  @@index([cityId])
}

model RssFeed {
  id                String      @id @default(cuid())
  url               String      @unique
  title             String?
  description       String?
  siteUrl           String?
  language          String?
  sourceType        String      @default("unknown")
  sourceQuality     String      @default("unverified")
  status            String      @default("pending")
  freshnessScore    Float?
  qualityScore      Float?
  lastFetchedAt     DateTime?
  lastItemDate      DateTime?
  fetchErrorCount   Int         @default(0)
  consecutiveErrors Int         @default(0)
  avgItemsPerWeek   Float?
  contentHash       String?
  canonicalUrl      String?
  discoveredBy      String?
  discoveryMethod   String?
  feedFormat        String?
  pilotState        String?
  discoveredAt      DateTime    @default(now())
  verifiedBy        String?
  verifiedAt        DateTime?
  geoScope          String      @default("local")
  lastAgentRun      String?
  lastAgentRunAt    DateTime?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  contentTags       String[]    @default([])
  industry          String?
  localizable       Boolean     @default(false)
  updateFrequency   String?
  feedAudits        FeedAudit[]
  feedGeos          FeedGeo[]
  items             RssItem[]

  @@index([status])
  @@index([sourceType])
  @@index([sourceQuality])
  @@index([freshnessScore])
  @@index([lastItemDate])
  @@index([geoScope])
  @@index([geoScope, status])
  @@index([industry])
}

model FeedGeo {
  id           String   @id @default(cuid())
  feedId       String
  zipId        String
  coverageType String
  confidence   Float    @default(0.5)
  source       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  feed         RssFeed  @relation(fields: [feedId], references: [id], onDelete: Cascade)
  zip          GeoZip   @relation(fields: [zipId], references: [id])

  @@unique([feedId, zipId])
  @@index([zipId])
  @@index([feedId])
  @@index([coverageType])
  @@index([confidence])
}

model RssItem {
  id              String      @id @default(cuid())
  feedId          String
  guid            String
  title           String?
  description     String?
  link            String?
  pubDate         DateTime?
  author          String?
  imageUrl        String?
  contentHash     String?
  categories      String[]    @default([])
  filterStatus    String      @default("pending")
  filterReason    String?
  blockedCategory String?
  relevanceScore  Float?
  usedInPost      Boolean     @default(false)
  usedAt          DateTime?
  postReference   String?
  fetchedAt       DateTime    @default(now())
  createdAt       DateTime    @default(now())
  itemAudits      ItemAudit[]
  feed            RssFeed     @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@unique([feedId, guid])
  @@index([feedId])
  @@index([pubDate])
  @@index([filterStatus])
  @@index([contentHash])
  @@index([usedInPost])
}

model FeedAudit {
  id          String   @id @default(cuid())
  feedId      String
  action      String
  oldValue    String?
  newValue    String?
  reason      String?
  performedBy String?
  createdAt   DateTime @default(now())
  feed        RssFeed  @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@index([feedId])
  @@index([createdAt])
  @@index([action])
}

model ItemAudit {
  id          String   @id @default(cuid())
  itemId      String
  action      String
  category    String?
  confidence  Float?
  reason      String?
  performedBy String?
  createdAt   DateTime @default(now())
  item        RssItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([createdAt])
  @@index([action])
}

model ScoutReport {
  id           String       @id @default(cuid())
  businessId   String
  userId       String
  status       String       @default("sent") // sent, expired
  storiesCount Int          @default(0)
  sentAt       DateTime     @default(now())
  expiresAt    DateTime
  createdAt    DateTime     @default(now())
  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories      ScoutStory[]

  @@index([businessId])
  @@index([userId])
  @@index([sentAt])
}

model ScoutStory {
  id              String      @id @default(cuid())
  scoutReportId   String
  title           String
  source          String
  sourceUrl       String      @default("")
  sourceType      String      @default("local") // local, industry, national
  pubDate         String      @default("")
  summary         String      @default("")
  relevance       String      @default("")
  suggestedAngle  String      @default("")
  createdAt       DateTime    @default(now())
  scoutReport     ScoutReport @relation(fields: [scoutReportId], references: [id], onDelete: Cascade)
  postPackages    PostPackage[]

  @@index([scoutReportId])
}

model MagicToken {
  id            String   @id @default(cuid())
  token         String   @unique
  userId        String
  businessId    String
  scoutReportId String?
  storyId       String?
  action        String   // create_post, review_stories, review_package
  nonce         String   @unique
  used          Boolean  @default(false)
  usedAt        DateTime?
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@index([nonce])
}

model PostPackage {
  id              String      @id @default(cuid())
  userId          String
  businessId      String
  storyId         String?
  scoutReportId   String?
  source          String      @default("daily_scout_email") // daily_scout_email, app_review
  workflowId      String?
  status          String      @default("generating") // generating, ready, downloaded, draft, rejected, posted
  postCopy        String?     @default("")
  headline        String?     @default("")
  cta             String?     @default("")
  hashtags        String[]    @default([])
  imageUrl        String?     @default("")
  storyTitle      String      @default("")
  storySource     String      @default("")
  storyUrl        String      @default("")
  storySummary    String      @default("")
  suggestedAngle  String      @default("")
  completedAt     DateTime?
  completionEmailSent Boolean  @default(false)
  warRoomStatus       String?   // approved, revise, reject
  warRoomScore        Int?
  warRoomRejectReason String?
  qaScore             Int?
  qaRejectReason      String?
  // Carousel fields
  carouselData          Json?    // Full CarouselPackage JSON
  carouselSlides        Json?    // Array of rendered slide metadata
  carouselImageUrls     String[] @default([]) // S3 URLs for slide images
  sourceAttribution     String?  // "Source: Publisher Name"
  // Credit tracking
  creditChargedAt     DateTime?
  creditCost          Int?         @default(0)
  creditTransactionId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  story           ScoutStory? @relation(fields: [storyId], references: [id])

  @@index([userId])
  @@index([businessId])
  @@index([workflowId])
  @@index([status])
  @@index([completionEmailSent, status])
}

// ─── Credit System ───────────────────────────────────────────────

model CreditAccount {
  id                      String   @id @default(cuid())
  businessId              String   @unique
  creditBalance           Int      @default(0)
  monthlyCreditAllowance  Int      @default(6)
  creditsRenewAt          DateTime?
  creditPlanName          String?  @default("starter")
  creditStatus            String   @default("active") // active, suspended, cancelled, billing_issue, past_due, canceled
  // Stripe Billing
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  stripeSubscriptionStatus String? // active, trialing, past_due, canceled, unpaid, incomplete, etc.
  stripePriceId           String?
  trialStartedAt          DateTime?
  trialEndsAt             DateTime?
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean  @default(false)
  lastInvoiceId           String?
  lastPaymentStatus       String?  // paid, failed, open, etc.
  accountClosedAt          DateTime?
  creditClosureExpiresAt   DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  business                Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  transactions            CreditTransaction[]
  creditLots              CreditLot[]

  @@index([creditStatus])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model CreditTransaction {
  id              String   @id @default(cuid())
  creditAccountId String
  businessId      String
  userId          String?
  postPackageId   String?
  transactionType String   // monthly_grant, admin_grant, starter_grant, image_post_charge, video_upgrade_charge, recharge_grant, refund, adjustment, failed_generation_refund, recharge_pending, credit_expired
  amount          Int      // positive = credit added, negative = credit spent
  balanceAfter    Int
  reason          String   @default("")
  idempotencyKey  String?  @unique
  expiresAt       DateTime?
  creditLotId     String?
  relatedCreditLotId String?
  // Stripe-ready placeholders
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  rechargePackId          String?
  metadata        Json?
  createdAt       DateTime @default(now())
  creditAccount   CreditAccount @relation(fields: [creditAccountId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
  @@index([postPackageId])
  @@index([transactionType])
  @@index([createdAt])
  @@index([creditLotId])
}

model CreditLot {
  id                  String   @id @default(cuid())
  businessId          String
  creditAccountId     String
  sourceTransactionId String?
  creditType          String   // starter, monthly, recharge, admin, refund
  originalAmount      Int
  remainingAmount     Int
  grantedAt           DateTime @default(now())
  expiresAt           DateTime?
  closureExpiresAt    DateTime?
  metadata            Json?
  createdAt           DateTime @default(now())
  creditAccount       CreditAccount @relation(fields: [creditAccountId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([creditAccountId])
  @@index([creditType])
  @@index([expiresAt])
  @@index([closureExpiresAt])
  @@index([remainingAmount])
}

model BusinessAsset {
  id                    String    @id @default(cuid())
  businessId            String
  tombstoneBusinessId   Int?
  tombstoneBusinessUuid String?
  uploadedByUserId      String
  assetType             String    // logo, brand_guidelines, product_photo, service_photo, menu_list, price_sheet, offer_sheet, owner_photo, staff_photo, certification, license, award, press_mention, storefront_photo, facility_photo, fleet_photo, service_area_map, landmark_photo, before_after_photo, testimonial_screenshot, review_screenshot, case_study, existing_ad, social_post, flyer_brochure, website_screenshot, negative_example, approved_claim, forbidden_claim, disclaimer, usage_rights_doc, font_notes, color_palette
  category              String    // brand, products_services, people_trust, location_service_area, proof_social_proof, compliance, creative_examples
  title                 String
  description           String    @default("")
  tags                  String[]  @default([])
  originalFilename      String
  mimeType              String
  fileSizeBytes         Int
  width                 Int?
  height                Int?
  cloudStoragePath      String    // S3/Cloudflare storage key
  publicUrl             String?   // direct URL for approved public assets
  thumbnailPath         String?   // storage key for generated thumbnail
  thumbnailUrl          String?   // direct URL for thumbnail
  isPublic              Boolean   @default(false)
  approvalStatus        String    @default("uploaded") // uploaded, pending_review, approved, rejected, expired, do_not_use, archived
  usageRights           String?   // owned, licensed, public_domain, customer_permission, unknown
  allowedChannels       String[]  @default([])
  disallowedChannels    String[]  @default([])
  priorityScore         Int       @default(0)
  expiresAt             DateTime?
  archivedAt            DateTime?
  // Text-entry assets (approved claims, forbidden claims, disclaimers)
  textContent           String?   // for text-based assets that are not file uploads
  sourcePlatform        String?   // for testimonials/reviews: google, yelp, facebook, etc.
  customerPermission    String?   // for testimonials: granted, pending, not_requested
  approvedForAds        Boolean   @default(false)
  exampleType           String?   // for creative examples: approved_example, past_ad, negative_example, competitor_reference
  pairTag               String?   // for before/after photos: links related assets
  pairRole              String?   // before, after
  expirationDate        DateTime? // for certifications/licenses
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  business              Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  uploadedBy            User      @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, category])
  @@index([businessId, approvalStatus])
  @@index([uploadedByUserId])
  @@index([approvalStatus])
}

model InternalCostLedger {
  id                    String   @id @default(cuid())
  businessId            String?
  userId                String?
  postPackageId         String?
  workflowId            String?
  taskId                String?
  provider              String?  // openai, fal, render, cloudflare_r2, abacus
  costType              String   // llm, image_generation, video_generation, render_runtime, r2_storage, r2_bandwidth, email, other
  estimatedCostUsd      Decimal  @default(0) @db.Decimal(10, 6)
  inputTokens           Int?
  outputTokens          Int?
  imageCount            Int?
  videoSeconds          Int?
  renderRuntimeSeconds  Int?
  retryCount            Int?
  metadata              Json?
  createdAt             DateTime @default(now())

  @@index([businessId])
  @@index([postPackageId])
  @@index([workflowId])
  @@index([costType])
  @@index([createdAt])
}

model SocialAccount {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  handle      String
  profileUrl  String?
  displayName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
  @@index([platform])
}

model SocialPost {
  id              String    @id @default(cuid())
  userId          String
  analysisId      String?
  caption         String
  hashtags        String[]  @default([])
  imageUrl        String?
  imagePrompt     String?
  rssItemId       String?
  rssItemTitle    String?
  rssItemLink     String?
  sourceType      String?
  newsAngle       String?
  platforms       String[]  @default([])
  postType        String    @default("general")
  status          String    @default("draft")
  scheduledFor    DateTime?
  publishedAt     DateTime?
  rejectedAt      DateTime?
  rejectReason    String?
  tradeAreaZip    String?
  briefScore      Float?
  patternType     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tombstoneTaskId       String?
  workflowId            String?
  businessId            String?
  sourceName            String?
  sourceArticleTitle    String?
  sourceArticleUrl      String?
  cta                   String?
  generationRunId       String?
  generationStartedAt   DateTime?
  generationCompletedAt DateTime?
  totalGenerationTimeMs Int?
  // Carousel fields
  carouselData          Json?    // Full CarouselPackage JSON (key_points, slides metadata, platform_notes)
  carouselSlides        Json?    // Array of {slide_number, headline, bullets, imageUrl} for rendered slides
  carouselImageUrls     String[] @default([]) // S3 URLs for slide images (ordered)
  sourceAttribution     String?  // "Source: Publisher Name"
  // ── GHL Social Planner publish tracking ─────────────────────────
  ghlPostId               String?    // Post ID returned by GHL Create Post API
  ghlLocationId           String?    // GHL location ID used for publishing
  ghlSocialAccountId      String?    // GHL Social Planner account ID used
  ghlSocialAccountName    String?    // Display name of the account published to
  ghlSocialOriginId       String?    // Platform-specific origin ID (e.g. FB page ID)
  ghlStatus               String?    // GHL's reported status: success | error | pending
  publishTraceId          String?    // Unique trace ID for diagnostics
  lastPublishAttemptAt    DateTime?  // Timestamp of last publish attempt
  publishResponseSummary  String?    // Safe summary of GHL response (no secrets)

  analysis        Analysis?      @relation(fields: [analysisId], references: [id])
  business        Business?      @relation(fields: [businessId], references: [id])
  generationRun   GenerationRun? @relation(fields: [generationRunId], references: [id])
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledPosts  ScheduledPost[]

  @@index([userId])
  @@index([status])
  @@index([analysisId])
  @@index([businessId])
  @@index([scheduledFor])
  @@index([createdAt])
  @@index([generationRunId])
  @@index([ghlPostId])
}

model GenerationRun {
  id                    String    @id @default(cuid())
  userId                String
  businessId            String?
  status                String    @default("creating_workflow")
  selectedStoryTitles   String[]  @default([])
  selectedStorySources  String[]  @default([])
  selectedStoryLinks    String[]  @default([])
  storyCount            Int       @default(0)
  workflowIds           String[]  @default([])
  tombstoneTaskIds      String[]  @default([])
  firstTaskId           String?
  clickedAt             DateTime
  runCreatedAt          DateTime  @default(now())
  apiReceivedAt         DateTime?
  workflowCreateStartedAt DateTime?
  workflowCreatedAt     DateTime?
  firstTaskCreatedAt    DateTime?
  firstTaskClaimedAt    DateTime?
  lastTaskCompletedAt   DateTime?
  socialPostCreatedAt   DateTime?
  socialPostReadyAt     DateTime?
  completedAt           DateTime?
  failedAt              DateTime?
  failStep              String?
  failError             String?
  totalTimeMs           Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialPosts           SocialPost[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ── Website Generation: Section-Level Feedback ──────────────────────────────
model SiteFeedback {
  id              String   @id @default(cuid())
  businessId      String?
  analysisId      String?
  workflowId      String?  // Tombstone workflow ID
  pageId          String   @default("home") // home, service_slug, etc.
  sectionId       String?  // hero, about, services, how_it_works, etc.
  target          String   // image | copy | layout | nav | service_page | whole_site | tone | mobile
  feedback        String   // Owner's feedback text
  requestedAction String?  // regenerate_image | revise_copy | revise_section | add_service_page | adjust_layout | revise_tone
  status          String   @default("pending") // pending | applied | rejected | needs_review
  appliedAt       DateTime?
  appliedInWorkflowId String?
  userId          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation("SiteFeedbackUser", fields: [userId], references: [id])

  @@index([analysisId])
  @@index([workflowId])
  @@index([businessId])
  @@index([status])
}

model PublishSettings {
  id              String   @id @default(cuid())
  businessId      String   @unique
  autoPublish     Boolean  @default(false)
  frequency       String   @default("3x_week")  // 1x_week, 2x_week, 3x_week, 5x_week, 1x_day, 2x_day, 3x_day
  preferredTime   String   @default("10:00")     // HH:mm in user's local time
  timezone        String   @default("America/Denver")
  platforms       String[] @default([])
  // Scheduler onboarding fields
  postingGoal     String?  // more_calls, website_visits, reviews, repeat_customers, brand_awareness, recruiting
  approvalMode    String   @default("review_first") // review_first, auto_after_approval, full_autopilot
  cadence         String   @default("standard")  // light, standard, growth, custom
  preferredDays   String[] @default([])  // mon, tue, wed, thu, fri, sat, sun
  preferredTimes  String[] @default([])  // HH:mm values
  defaultChannels String[] @default([])  // facebook, google_business, instagram, linkedin
  autopilotEnabled Boolean @default(false)
  onboardingComplete Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([autoPublish])
}

model SocialConnection {
  id                  String    @id @default(cuid())
  businessId          String
  platform            String    // facebook, google_business, instagram, linkedin, tiktok
  externalAccountId   String?   // e.g. FB page ID, GMB location ID
  displayName         String?   // e.g. "My Restaurant - Facebook Page"
  profileUrl          String?   // Link to the social profile
  accessToken         String?   // Encrypted token for publishing
  refreshToken        String?   // For OAuth refresh flows
  tokenExpiresAt      DateTime? // When the access token expires
  permissionsStatus   String    @default("pending") // pending, connected, expired, revoked, error
  lastCheckedAt       DateTime? // Last time we verified the connection
  lastPublishedAt     DateTime? // Last time we published through this connection
  errorMessage        String?   // Last error if connection failed
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  business            Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, platform])
  @@index([businessId])
  @@index([platform])
  @@index([permissionsStatus])
}

model ScheduledPost {
  id                  String    @id @default(cuid())
  businessId          String
  userId              String
  socialPostId        String?   // Links to existing SocialPost if sourced from generation
  // Content (copied from or independent of SocialPost)
  caption             String
  imageUrl            String?
  hashtags            String[]  @default([])
  cta                 String?
  platforms           String[]  @default([]) // which platforms to post on
  // Scheduling
  scheduledFor        DateTime  // When the post should go out
  timezone            String    @default("America/Denver")
  // Approval workflow
  status              String    @default("needs_approval") // draft, needs_approval, approved, scheduled, publishing, published, failed, paused, revision_requested
  approvalRequired    Boolean   @default(true)
  approvedById        String?   // User who approved
  approvedAt          DateTime?
  // Revision tracking
  revisionRequestText String?
  revisionRequestedAt DateTime?
  revisionCount       Int       @default(0)
  // Publishing
  publishedAt         DateTime?
  failureReason       String?
  publishAttempts     Int       @default(0)
  // Content lane/source info
  lane                String?   // website, news, holiday
  sourceType          String?   // generation, user_draft, carousel
  // Metadata
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  business            Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user                User      @relation("ScheduledPostUser", fields: [userId], references: [id], onDelete: Cascade)
  approvedBy          User?     @relation("ScheduledPostApprover", fields: [approvedById], references: [id])
  socialPost          SocialPost? @relation(fields: [socialPostId], references: [id])

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, scheduledFor])
  @@index([userId])
  @@index([status])
  @@index([scheduledFor])
}
