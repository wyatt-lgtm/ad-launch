  @@unique([businessId, packId])
  @@index([businessId])
  @@index([packId])
  @@index([status])
}

model SharedAssetAuditLog {
  id            String   @id @default(cuid())
  sharedAssetId String?
  packId        String?
  businessId    String?
  userId        String?
  action        String // created, updated, approved, rejected, revoked, pack_granted, pack_revoked, downloaded, viewed
  details       Json? // freeform details
  ipAddress     String?
  createdAt     DateTime @default(now())

  sharedAsset SharedAsset? @relation(fields: [sharedAssetId], references: [id], onDelete: SetNull)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sharedAssetId])
  @@index([userId])
  @@index([businessId])
  @@index([action])
  @@index([createdAt])
