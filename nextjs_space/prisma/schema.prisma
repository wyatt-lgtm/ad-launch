model OrganicPositionHistory {
  id                     String   @id @default(cuid())
  businessId             String
  keywordId              String?
  locationId             String?
  observedAt             DateTime @default(now())
  selfPosition           Int?
  selfUrl                String?
  bestCompetitorPosition Int?
  topCompetitorId        String?
  localPackPosition      Int?
  paidAdPosition         Int?
  // organic_rank_bucket: top_1 | top_3 | top_10 | page_2 | not_found
  organicRankBucket      String?
  visibilityScore        Float?
  dataSource             String?
  createdAt              DateTime @default(now())

  business Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  keyword  SearchIntelligenceKeyword?  @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  location SearchIntelligenceLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, keywordId])
  @@index([observedAt])
}

model SearchIntelligenceRecommendation {
  id                 String   @id @default(cuid())
  businessId         String
  runId              String?
  // recommendation_type: create_service_page | improve_page | add_internal_links
  //   | launch_paid_keyword | add_negative_keyword | monitor_competitor | improve_local_pack
  //   | create_city_page | create_county_page | update_title_meta | add_tracking | review_campaign_gap
  recommendationType String
  title              String
  evidenceJson       Json?
  suggestedAction    String?  @db.Text
  // priority: low | medium | high | critical
  priority           String   @default("medium")
  confidenceScore    Float    @default(0)
  // status: open | in_review | accepted | dismissed | done
  status             String   @default("open")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  business Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  run      SearchIntelligenceRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, recommendationType])
}

// ════════════════════════════════════════════════════════════════════
//  SERP auditability: manual comparison notes + variance summaries
//  These treat DataForSEO output as observation snapshots — never as a
//  single absolute ranking truth. NO Google scraping / browser automation.
// ════════════════════════════════════════════════════════════════════

// ── Keyword/Location bulk file import (audit batch) ────────────────
// Records each uploaded keyword/location file: parsed counts, status, and a
// JSON summary of row-level results (for download/audit). Business-scoped.
model SearchIntelligenceKeywordImport {
  id               String   @id @default(cuid())
  businessId       String
  uploadedByUserId String?
  fileName         String?
  fileType         String? // csv | tsv | txt
  rowCount         Int      @default(0)
  importedCount    Int      @default(0)
  duplicateCount   Int      @default(0)
  needsReviewCount Int      @default(0)
  invalidCount     Int      @default(0)
  keywordCreated   Int      @default(0)
  locationCreated  Int      @default(0)
  status           String   @default("completed") // completed | partial | failed
  errorSummary     String?  @db.Text
  rowsJson         Json? // row-level parsed details for audit / error report
  createdAt        DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, createdAt])
}

/// A human-recorded comparison note for a run. Lets an admin log that a
/// local/incognito browser showed a different SERP, WITHOUT that ever being
/// treated as automated Google scraping. Purely manual, manually entered.
model SearchManualComparisonNote {
  id                   String   @id @default(cuid())
  businessId           String
  runId                String?
  keyword              String?
  location             String?
  manualObservedAt     DateTime @default(now())
  manualNotes          String?  @db.Text
  manualTopResultsJson Json? // optional list of {position, domain, url, title}
  screenshotRef        String? // optional R2 object key for a manual screenshot
  createdByUserId      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  business Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  run      SearchIntelligenceRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, runId])
  @@index([createdAt])
}

/// Future-safe SERP variance rollup for a keyword+location over a period.
/// Populated from multiple observation snapshots so we can distinguish
/// stable competitors (repeated presence) from volatile ones (one-offs).
model SearchSerpVarianceSummary {
  id                       String    @id @default(cuid())
  businessId               String
  keywordId                String?
  locationId               String?
  periodStart              DateTime?
  periodEnd                DateTime?
  observationsCount        Int       @default(0)
  stableDomainsJson        Json? // domains seen in multiple observations
  volatileDomainsJson      Json? // domains seen only once
  selfSeenCount            Int       @default(0)
  topCompetitorDomainsJson Json?
  confidenceScore          Float     @default(0)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  business Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  keyword  SearchIntelligenceKeyword?  @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  location SearchIntelligenceLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, keywordId])
  @@index([businessId, locationId])
  @@index([createdAt])
}

// ════════════════════════════════════════════════════════════════════
//  SEO Research Consumption Layer
//  Turns DataForSEO SERP observations (provider-returned top URLs ONLY)
//  into structured competitor page analyses → meta-analysis → page /
//  content / video briefs that production website + content + video
//  generation can CONSUME. NO Google scraping, NO browser automation as a
//  data source, NO competitor copying (structure / intent / gaps only).
//  All records are business-scoped; raw provider payloads live in R2 and
//  are referenced here by object key. Evidence (provider task_id +
//  check_url) is preserved on every analysis.
// ════════════════════════════════════════════════════════════════════

/// Per-competitor SERP result page analysis. Built ONLY from URLs the
/// provider (DataForSEO) returned for a keyword/location SERP. Stores what
/// the page covers (structure / intent / gaps) — never copied content.
model SeoCompetitorPageAnalysis {
  id             String  @id @default(cuid())
  businessId     String
  metaAnalysisId String?
  // external evidence links (scalar, indexed — not hard relations)
  runId          String?
  keywordId      String?
  locationId     String?
  // provider evidence
  providerTaskId String?
  checkUrl       String? @db.Text
  rawSnapshotRef String? // R2 object key for the raw fetched page payload

  domain          String?
  url             String  @db.Text
  rankGroup       Int?
  rankAbsolute    Int?
  // result_type: organic | local_pack | maps | paid | featured_snippet
  //   | people_also_ask | reddit | forum | youtube | video | other
  resultType      String  @default("organic")
  // classified_input: service_page | question_input | video_input
  classifiedInput String  @default("service_page")

  pageTitle              String? @db.Text
  metaDescription        String? @db.Text
  h1                     String? @db.Text
  headingsJson           Json?
  topicsJson             Json?
  faqsJson               Json?
  schemaTypesJson        Json?
  ctaSummary             String? @db.Text
  trustElementsJson      Json?
  localTermsJson         Json?
  mediaElementsJson      Json?
  videoElementsJson      Json?
  contentGapsJson        Json?
  conversionElementsJson Json?
  analysisSummary        String? @db.Text

  // status: pending | complete | failed | skipped
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business     Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  metaAnalysis SeoContentMetaAnalysis? @relation(fields: [metaAnalysisId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([metaAnalysisId])
  @@index([businessId, resultType])
  @@index([businessId, classifiedInput])
  @@index([businessId, domain])
}

/// Aggregated meta-analysis across competitor page analyses for a target
/// keyword + location + service line. Captures common structure, question
/// patterns, content gaps, and recommended angle/sections/FAQs/schema/CTAs
/// + recommended video topics. This is the source record consumed by page,
/// content and video brief generation.
model SeoContentMetaAnalysis {
  id         String  @id @default(cuid())
  businessId String
  // external evidence links (scalar, indexed)
  runId      String?
  keywordId  String?
  locationId String?

  targetKeyword      String?
  targetLocation     String?
  serviceLine        String?
  marketOrientation  String? // local | regional | national
  dataSource         String? @default("dataforseo")
  // provider evidence
  providerTaskId     String?
  checkUrl           String? @db.Text
  competitorUrlsJson Json?

  // aggregated structural patterns
  commonHeadingsJson     Json?
  commonTopicsJson       Json?
  commonFaqsJson         Json?
  commonSchemaJson       Json?
  commonCtasJson         Json?
  trustElementsJson      Json?
  localTermsJson         Json?
  mediaPatternsJson      Json?
  videoPatternsJson      Json?
  conversionPatternsJson Json?
  contentGapsJson        Json?

  // question / intent patterns (extracted from PAA, Reddit, forums, FAQs)
  commonCustomerQuestionsJson Json?
  questionPatternsJson        Json?
  listiclePatternsJson        Json?
  comparisonTopicsJson        Json?
  warningSignTopicsJson       Json?
  costTopicsJson              Json?
  serviceProcessTopicsJson    Json?
  objectionTopicsJson         Json?
  paaQuestionsJson            Json?
  faqQuestionsJson            Json?

  // recommendations (intent-derived, not copied)
  recommendedAngle           String? @db.Text
  recommendedSectionsJson    Json?
  recommendedFaqsJson        Json?
  recommendedSchemaJson      Json?
  recommendedCtasJson        Json?
  recommendedVideoTopicsJson Json?

  confidenceScore Float?   @default(0)
  // status: pending | complete | stale | needs_review | failed
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business           Business                    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  competitorAnalyses SeoCompetitorPageAnalysis[]
  pageBriefs         SeoPageBrief[]
  contentBriefs      SeoContentBrief[]
  videoBriefs        SeoVideoBrief[]
  extractedQuestions SeoExtractedQuestion[]

  @@index([businessId])
  @@index([businessId, status])
  @@index([businessId, targetKeyword])
  @@index([businessId, serviceLine])
  @@index([createdAt])
}

/// A single customer question / topic extracted from question-type inputs
/// (PAA, Reddit, forums, FAQs) or video inputs (YouTube). Classified by
/// topic_type and funnel stage with a recommended content use + priority.
model SeoExtractedQuestion {
  id             String  @id @default(cuid())
  businessId     String
  metaAnalysisId String?

  questionText          String  @db.Text
  // topic_type: warning_signs | comparison | cost | timing | necessity
  //   | process | risk | DIY_vs_professional | objection | FAQ
  //   | local_modifier | video_topic
  topicType             String  @default("FAQ")
  frequencyCount        Int     @default(1)
  sourceUrlsJson        Json?
  sourceResultTypesJson Json?
  // funnel_stage: awareness | consideration | decision | retention
  funnelStage           String?
  // recommended_content_use: service_page_section | FAQ | blog_article
  //   | video_script | short_video | carousel | email | social_post
  //   | landing_page_section
  recommendedContentUse String?
  // priority: low | medium | high | critical
  priority              String  @default("medium")
  notes                 String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business     Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  metaAnalysis SeoContentMetaAnalysis? @relation(fields: [metaAnalysisId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([metaAnalysisId])
  @@index([businessId, topicType])
  @@index([businessId, priority])
}

/// A structured page brief derived from a meta-analysis. Consumed by the
/// production website build (George structures, Ogilvy writes copy, Tom
/// Hopkins applies conversion/CTA, Peter validates). Approval is required
/// before a page is generated from it (no auto-publish).
model SeoPageBrief {
  id               String  @id @default(cuid())
  businessId       String
  metaAnalysisId   String?
  websiteProjectId String?
  websitePageId    String? // page that consumed this brief (scalar record)

  // target_page_type: home | service | location | city | county | about
  //   | contact | blog | landing | other
  targetPageType String @default("service")

  recommendedSlug                 String?
  recommendedMetaTitle            String?
  recommendedMetaDescription      String? @db.Text
  recommendedH1                   String? @db.Text
  recommendedSectionsJson         Json?
  recommendedFaqsJson             Json?
  recommendedSchemaJson           Json?
  internalLinkRecommendationsJson Json?
  ctaRecommendationsJson          Json?
  formRecommendationsJson         Json?
  trackingRecommendationsJson     Json?
  differentiationAngle            String? @db.Text
  evidenceSummary                 String? @db.Text
  sourceCompetitorAnalysisIdsJson Json?

  // status: draft | ready_for_review | approved | used_in_page | stale | rejected
  status           String    @default("draft")
  approvedByUserId String?
  approvedAt       DateTime?
  // admin override of the research gate (e.g. generate page without research)
  overrideByUserId String?
  overrideReason   String?   @db.Text

  // WF3 (Website-SEO AI workflow) dispatch tracking. Populated when an approved
  // brief is dispatched to the Tombstone SEO page workflow. Read-only display
  // layer (P10) uses wf3WorkflowId to fetch normalized quality/QA data.
  wf3WorkflowId         String?
  wf3DispatchedAt       DateTime?
  wf3DispatchedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business        Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  metaAnalysis    SeoContentMetaAnalysis? @relation(fields: [metaAnalysisId], references: [id], onDelete: SetNull)
  pagesUsingBrief WebsitePage[]

  @@index([businessId])
  @@index([metaAnalysisId])
  @@index([businessId, status])
  @@index([businessId, targetPageType])
  @@index([wf3WorkflowId])
}

/// A content brief (blog/guide/FAQ/landing/social/email/video script/etc.)
/// derived from a meta-analysis. Consumed by content generation. Never
/// auto-published.
model SeoContentBrief {
  id             String  @id @default(cuid())
  businessId     String
  metaAnalysisId String?

  // content_type: blog_article | guide | faq_page | landing_page
  //   | social_post | email | video_script | short_video | carousel
  contentType                  String  @default("blog_article")
  recommendedTitle             String? @db.Text
  recommendedOutlineJson       Json?
  recommendedFaqsJson          Json?
  recommendedCta               String? @db.Text
  recommendedInternalLinksJson Json?
  recommendedMediaJson         Json?
  audience                     String? @db.Text
  evidenceSummary              String? @db.Text

  // status: draft | ready_for_review | approved | used | stale | rejected
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business     Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  metaAnalysis SeoContentMetaAnalysis? @relation(fields: [metaAnalysisId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([metaAnalysisId])
  @@index([businessId, status])
  @@index([businessId, contentType])
}

/// A video brief derived from a meta-analysis (built from video-input /
/// question-input patterns). Consumed by video generation (Don Draper for
/// media patterns). Never auto-published.
model SeoVideoBrief {
  id             String  @id @default(cuid())
  businessId     String
  metaAnalysisId String?

  // video_type: short_form | explainer | service_overview | faq_answer
  //   | local_service_intro | testimonial_prompt | comparison | myth_buster
  videoType                    String  @default("short_form")
  hook                         String? @db.Text
  recommendedScriptOutlineJson Json?
  keyQuestionsToAnswerJson     Json?
  visualShotsJson              Json?
  recommendedCta               String? @db.Text
  audience                     String? @db.Text
  // funnel_stage: awareness | consideration | decision | retention
  funnelStage                  String?
  evidenceSummary              String? @db.Text

  // status: draft | ready_for_review | approved | used | stale | rejected
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business     Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  metaAnalysis SeoContentMetaAnalysis? @relation(fields: [metaAnalysisId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([metaAnalysisId])
  @@index([businessId, status])
  @@index([businessId, videoType])
}

// ════════════════════════════════════════════════════════════════════
//  Two-Stage Website Workflow (Concept → Production)
//  Concept records and Production records are kept fully separate so a
//  concept revision can never overwrite generated production pages.
// ════════════════════════════════════════════════════════════════════

/// One website project per business. Tracks which stage the website is in
/// and the independent concept + production status machines.
model WebsiteProject {
  id         String @id @default(cuid())
  businessId String

  projectName String?

  // current_stage: concept | production
  currentStage String @default("concept")

  // concept_status: not_started | generating | ready_for_review |
  //                 revision_requested | approved | rejected | archived
  conceptStatus String @default("not_started")

  // production_status: not_started | waiting_for_concept_approval | planning |
  //                    generating | qa_pending | qa_failed | ready_for_review |
  //                    approved | published | archived
  productionStatus String @default("not_started")

  // Pointers to the active approved concept and current production version
  approvedConceptVersionId   String?
  currentProductionVersionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business           Business                     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  concepts           WebsiteConcept[]
  productions        WebsiteProduction[]
  serviceDiscoveries WebsiteServiceDiscovery[]
  sitemaps           WebsiteSitemap[]
  pageCopies         WebsitePageCopy[]
  imageBriefs        WebsiteImageBrief[]
  generatedImages    WebsiteGeneratedImageAsset[]
  pages              WebsitePage[]
  sections           WebsiteSection[]
  assets             WebsiteAsset[]
  qaResults          WebsiteQaResult[]
  deploymentTargets  SiteDeploymentTarget[]
  builds             SiteBuild[]
  mobileQas          WebsiteMobileQa[]
  previewApprovals   WebsitePreviewApproval[]

  @@index([businessId])
  @@index([conceptStatus])
  @@index([productionStatus])
}

/// A concept website version (single-page creative direction produced by the
/// existing 8-step Tombstone concept workflow). Never overwritten by production.
model WebsiteConcept {
  id               String @id @default(cuid())
  businessId       String
  websiteProjectId String

  // Pointer back to the Tombstone concept workflow that produced this concept
  workflowId  String?
  finalTaskId String?

  conceptHtml    String? @db.Text
  conceptSummary String? @db.Text

  // Creative direction captured from the concept workflow for reuse by production
  designDirectionJson Json?
  brandDirectionJson  Json?
  imageDirectionJson  Json?
  ctaDirectionJson    Json?

  // status: generating | ready_for_review | revision_requested |
  //         approved | rejected | archived
  status  String @default("generating")
  version Int    @default(1)

  approvedByUserId String?
  approvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business  Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project   WebsiteProject    @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)
  assets    WebsiteAsset[]
  qaResults WebsiteQaResult[]

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([status])
  @@index([workflowId])
}

/// A production website version (multi-page SEO build). Only created after a
/// concept has been approved. Holds the sitemap and high-level metadata; the
/// individual pages live in WebsitePage records.
model WebsiteProduction {
  id               String @id @default(cuid())
  businessId       String
  websiteProjectId String

  // The approved concept this production build was derived from (creative direction)
  sourceConceptId String?

  workflowId String?

  // status: planning | generating | qa_pending | qa_failed |
  //         ready_for_review | approved | published | archived
  status  String @default("planning")
  version Int    @default(1)

  sitemapJson Json?
  robotsTxt   String? @db.Text
  schemaJson  Json?

  // qa_status: pending | passed | failed
  qaStatus String @default("pending")

  approvedByUserId String?
  approvedAt       DateTime?
  publishedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business  Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project   WebsiteProject    @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)
  pages     WebsitePage[]
  sections  WebsiteSection[]
  assets    WebsiteAsset[]
  qaResults WebsiteQaResult[]
  builds    SiteBuild[]

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([status])
}

/// A first-class production page (home, service, city/county landing page, etc.).
model WebsitePage {
  id               String @id @default(cuid())
  businessId       String
  websiteProjectId String
  productionId     String

  // page_type: home | service | location | city | county | about | contact | blog | other
  pageType String @default("other")

  title              String?
  slug               String?
  path               String?
  metaTitle          String?
  metaDescription    String? @db.Text
  canonicalUrl       String?
  h1                 String?
  targetKeywordsJson Json?

  serviceLine       String?
  marketOrientation String? // local | regional | national
  city              String?
  county            String?
  state             String?

  // status: draft | generating | ready | needs_review | approved | archived
  status    String @default("draft")
  sortOrder Int    @default(0)

  html String? @db.Text

  // SEO research gate: which page brief this page was built from + status.
  // seo_research_status: research_ready | research_missing | research_stale
  //   | provider_unavailable | generated_without_research | seo_research_missing
  seoBriefId        String?
  seoResearchStatus String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project    WebsiteProject    @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)
  production WebsiteProduction @relation(fields: [productionId], references: [id], onDelete: Cascade)
  sections   WebsiteSection[]
  assets     WebsiteAsset[]
  seoBrief   SeoPageBrief?     @relation(fields: [seoBriefId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([productionId])
  @@index([pageType])
  @@index([status])
  @@index([seoBriefId])
}

/// A content section within a production page (hero, services, about, CTA, etc.).
model WebsiteSection {
  id               String  @id @default(cuid())
  businessId       String
  websiteProjectId String
  pageId           String
  productionId     String?

  // section_type: hero | services | about | how_it_works | testimonials |
  //               faq | cta | contact | gallery | other
  sectionType String @default("other")

  heading   String?
  body      String? @db.Text
  ctaText   String?
  ctaTarget String?

  assetIdsJson Json?
  sortOrder    Int   @default(0)

  // status: draft | ready | needs_review | approved | archived
  status String @default("draft")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project    WebsiteProject     @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)
  page       WebsitePage        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  production WebsiteProduction? @relation(fields: [productionId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([pageId])
  @@index([sectionType])
}

/// An image / media asset used by a concept or production page/section.
model WebsiteAsset {
  id               String @id @default(cuid())
  businessId       String
  websiteProjectId String

  conceptId    String?
  productionId String?
  pageId       String?
  sectionId    String?

  // asset_type: hero_image | section_image | logo | icon | background | other
  assetType String @default("other")

  r2Key     String?
  publicUrl String?
  altText   String?
  width     Int?
  height    Int?

  // status: pending | ready | failed | archived
  status String @default("ready")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project    WebsiteProject     @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)
  concept    WebsiteConcept?    @relation(fields: [conceptId], references: [id], onDelete: SetNull)
  production WebsiteProduction? @relation(fields: [productionId], references: [id], onDelete: SetNull)
  page       WebsitePage?       @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([conceptId])
  @@index([productionId])
  @@index([pageId])
}

/// A QA / quality-review result for a concept or production build.
model WebsiteQaResult {
  id               String @id @default(cuid())
  businessId       String
  websiteProjectId String

  conceptId    String?
  productionId String?

  // qa_type: concept_war_room | production_qa | seo_audit | accessibility | other
  qaType  String  @default("other")
  qaAgent String?

  // verdict: APPROVED | REJECTED | WARNING | PENDING
  verdict String @default("PENDING")

  gatesJson    Json?
  failuresJson Json?

  createdAt DateTime @default(now())

  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project    WebsiteProject     @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)
  concept    WebsiteConcept?    @relation(fields: [conceptId], references: [id], onDelete: SetNull)
  production WebsiteProduction? @relation(fields: [productionId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([conceptId])
  @@index([productionId])
}

// ════════════════════════════════════════════════════════════════════
//  Static-First Site Generation — Deployment Targets / Builds / Env Vars
//  Platform-neutral deployment data model. Additive only; no live deploy
//  is performed by these records — they describe WHERE a generated static
//  site could be published and track build artifacts. Default target type
//  is `hostgator_static`. Secrets are NEVER stored here — only references.
// ════════════════════════════════════════════════════════════════════

/// A deployment destination for a generated static site. Describes the
/// target platform + its (non-secret) configuration. Credentials are stored
/// externally and referenced via `credentialsRef` only.
model SiteDeploymentTarget {
  id               String  @id @default(cuid())
  businessId       String
  websiteProjectId String?

  // target_type: hostgator_static | cloudflare_pages | vercel |
  //              wordpress_export | manual_export
  targetType String @default("hostgator_static")

  name String?

  // status: draft | configured | disabled | archived
  status String @default("draft")

  domain         String?
  siteUrl        String?
  deployBasePath String?

  gitRepoUrl      String?
  gitBranch       String?
  buildCommand    String?
  outputDirectory String?

  cloudflareZoneId String?
  hostgatorHostRef String?
  vercelProjectId  String?
  wordpressSiteUrl String?

  // Reference (NOT the value) to externally-stored deploy credentials.
  credentialsRef String?

  configJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business         Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project          WebsiteProject?           @relation(fields: [websiteProjectId], references: [id], onDelete: SetNull)
  builds           SiteBuild[]
  envVars          SiteEnvironmentVariable[]
  previewApprovals WebsitePreviewApproval[]

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([targetType])
  @@index([status])
}

/// A build of a generated static site. Tracks the build lifecycle and the
/// artifact manifest. NO deploy execution happens here in this phase — the
/// furthest a build can advance autonomously is `ready_for_preview`.
model SiteBuild {
  id                  String  @id @default(cuid())
  businessId          String
  websiteProjectId    String
  websiteProductionId String?
  deploymentTargetId  String?

  // build_status: draft | building | build_failed | ready_for_preview |
  //               approved_for_deploy | deploying | deployed | deploy_failed |
  //               archived
  buildStatus String @default("draft")
  buildNumber Int    @default(1)

  gitCommitSha String?
  sourceRef    String?
  outputRef    String?
  previewUrl   String?

  artifactManifestJson Json?

  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?   @db.Text

  createdByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business         Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project          WebsiteProject           @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)
  production       WebsiteProduction?       @relation(fields: [websiteProductionId], references: [id], onDelete: SetNull)
  deploymentTarget SiteDeploymentTarget?    @relation(fields: [deploymentTargetId], references: [id], onDelete: SetNull)
  mobileQas        WebsiteMobileQa[]
  previewApprovals WebsitePreviewApproval[]

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([websiteProductionId])
  @@index([deploymentTargetId])
  @@index([buildStatus])
}

/// Milestone 7 — Mobile / responsive QA result for a generated static preview
/// package. Read-only inspection of the M6 static build (re-rendered from the
/// approved sitemap-first blueprint). NEVER deploys, publishes, generates
/// images/copy, or advances the SiteBuild status. Durable + auditable copy of
/// the QA report lives in `qaJson`; artifacts never contain secrets/signed URLs.
model WebsiteMobileQa {
  id               String  @id @default(cuid())
  businessId       String
  websiteProjectId String?
  siteBuildId      String

  // status: pending | running | passed | failed | blocked | error | archived
  status String @default("pending")

  qaJson Json?

  score              Int?
  passed             Boolean @default(false)
  checkedRoutesCount Int     @default(0)
  failedRoutesCount  Int     @default(0)
  warningCount       Int     @default(0)

  createdByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business         Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project          WebsiteProject?          @relation(fields: [websiteProjectId], references: [id], onDelete: SetNull)
  siteBuild        SiteBuild                @relation(fields: [siteBuildId], references: [id], onDelete: Cascade)
  previewApprovals WebsitePreviewApproval[]

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([siteBuildId])
  @@index([status])
}

/// Milestone 8 — Preview approval + deployment-readiness gate for a generated
/// static preview package (built in M6, QA'd in M7). Records a human review
/// decision on whether the preview is ready for a FUTURE, separately-gated
/// deployment milestone. This model NEVER deploys, publishes, launches, changes
/// DNS, uploads to hosting, generates images/copy, or rebuilds the static site.
/// It never advances SiteBuild.buildStatus to deployed/live/published. The
/// durable, auditable readiness report lives in `readinessJson`; artifacts never
/// contain secrets or signed URLs. Status values: pending_review |
/// approved_for_deployment_readiness | approved_preview_only_target_incomplete |
/// rejected | blocked | archived. (NEVER deployed/published/live/launched.)
model WebsitePreviewApproval {
  id                 String  @id @default(cuid())
  businessId         String
  websiteProjectId   String?
  siteBuildId        String
  mobileQaId         String?
  deploymentTargetId String?

  // status: pending_review | approved_for_deployment_readiness |
  //         approved_preview_only_target_incomplete | rejected | blocked | archived
  status String @default("pending_review")

  readinessJson Json?

  approvalNotes   String?
  rejectionReason String?

  approvedByUserId String?
  rejectedByUserId String?
  approvedAt       DateTime?
  rejectedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business         Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project          WebsiteProject?       @relation(fields: [websiteProjectId], references: [id], onDelete: SetNull)
  siteBuild        SiteBuild             @relation(fields: [siteBuildId], references: [id], onDelete: Cascade)
  mobileQa         WebsiteMobileQa?      @relation(fields: [mobileQaId], references: [id], onDelete: SetNull)
  deploymentTarget SiteDeploymentTarget? @relation(fields: [deploymentTargetId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([siteBuildId])
  @@index([mobileQaId])
  @@index([status])
}

/// An environment variable associated with a deployment target. Public
/// (NEXT_PUBLIC_*) values may be stored inline via `valueRef`; secrets must
/// NOT use the NEXT_PUBLIC_ prefix and store only an external reference.
/// Secret values are NEVER logged or stored in plaintext here.
model SiteEnvironmentVariable {
  id                 String  @id @default(cuid())
  businessId         String
  deploymentTargetId String?

  key      String
  valueRef String?
  isPublic Boolean @default(false)
  isSecret Boolean @default(false)

  // environment: production | preview | development | all
  environment String @default("production")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business         Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  deploymentTarget SiteDeploymentTarget? @relation(fields: [deploymentTargetId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([deploymentTargetId])
  @@index([environment])
}

// ════════════════════════════════════════════════════════════════════
//  Provider Usage / Quota Tracking (Search Intelligence SEO/SERP providers)
//  Lightweight per-business usage ledger so no single business can silently
//  consume all provider quota. Written for every external provider request
//  (e.g. DataForSEO). NEVER stores credentials — only the endpoint + counts.
// ════════════════════════════════════════════════════════════════════
model ProviderUsageEvent {
  id                 String   @id @default(cuid())
  businessId         String
  provider           String // dataforseo | ahrefs | google_ads | ...
  endpoint           String // provider endpoint path that was called
  queryType          String? // serp_organic | serp_with_paid | keyword_metrics | health_check
  targetKeyword      String?
  targetLocation     String?
  requestCount       Int      @default(1)
  responseStatus     String? // ok | error | empty | disabled | missing_credentials
  providerStatusCode Int? // provider status_code (e.g. DataForSEO 20000) or HTTP code
  unitsUsed          Float? // tasks/units consumed if reported
  costEstimate       Float? // provider-reported cost if available
  // ── Audit metadata (no credentials) ────────────────────────────────
  providerTaskId     String? // DataForSEO task id for this request
  checkUrl           String?  @db.Text // DataForSEO check_url
  providerDatetime   String? // provider-reported capture datetime
  locationCode       Int? // resolved location_code
  isSandbox          Boolean  @default(false)
  errorMessage       String?  @db.Text
  runId              String?
  createdAt          DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([businessId, provider])
  @@index([businessId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────
// Sitemap-first Website Generation (Milestone 1)
// Additive, business-scoped artifact storage for the sitemap-first workflow:
//   Service Discovery → Sitemap Proposal → User Revisions → Approval.
// No page copy, no image generation, no publishing, no deployment here.
// ─────────────────────────────────────────────────────────────────────

/// Classified service-discovery snapshot for a business (website_service_discovery.json).
model WebsiteServiceDiscovery {
  id               String  @id @default(cuid())
  businessId       String
  websiteProjectId String?

  // Full classified discovery artifact (services with confirmationStatus/source/evidence/confidence).
  discoveryJson          Json
  // Denormalized counts for quick UI/gates.
  confirmedCount         Int  @default(0)
  likelyCount            Int  @default(0)
  needsConfirmationCount Int  @default(0)
  rejectedCount          Int  @default(0)

  source  String @default("agent_research")
  version Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project  WebsiteProject? @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([websiteProjectId])
}

/// The website_sitemap.json artifact for a business (hub-and-spoke plan + approval state).
model WebsiteSitemap {
  id               String  @id @default(cuid())
  businessId       String
  websiteProjectId String?

  // approval_status: draft | pending_user_review | approved | rejected
  approvalStatus String @default("pending_user_review")

  businessName String?
  industry     String?
  websiteGoal  String?

  // Full sitemap artifact JSON (schema per Milestone 1 spec).
  sitemapJson Json

  version          Int       @default(1)
  approvedByUserId String?
  approvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business  Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project   WebsiteProject?          @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)
  revisions WebsiteSitemapRevision[]

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([approvalStatus])
}

/// Audit record of a user revision to a sitemap (add/remove/rename/reorder page,
/// add/remove section, confirm services, approve). User-added pages record source=user_requested.
model WebsiteSitemapRevision {
  id         String @id @default(cuid())
  businessId String
  sitemapId  String

  // action: add_page | remove_page | rename_page | reorder_page |
  //         add_section | remove_section | confirm_services | approve | other
  action String

  detailJson Json?

  // For user-added pages.
  pageTitle         String?
  pageSlug          String?
  pageType          String?
  pageSource        String? // user_requested for user-added pages
  requestedByUserId String?

  createdAt DateTime @default(now())

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sitemap  WebsiteSitemap @relation(fields: [sitemapId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([sitemapId])
}

/// Generated page copy (Milestone 3). One row per page per generation, scoped by
/// business (+ optional project) and tied to the approved sitemap it was generated
/// from. Copy is DRAFT for user review; it is never auto-approved, published, or
/// deployed. `copyJson` holds the full PageCopy artifact (schema per M3 lib).
model WebsitePageCopy {
  id               String  @id @default(cuid())
  businessId       String
  websiteProjectId String?
  sitemapId        String

  slug     String
  pageType String

  // Authoritative H1 copied from the approved sitemap.
  h1 String?

  // stage: draft (copy for review). status: draft | approved (reserved).
  stage  String @default("draft")
  status String @default("draft")

  // Full PageCopy artifact JSON.
  copyJson Json

  version           Int     @default(1)
  generatedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project  WebsiteProject? @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([sitemapId])
  @@index([businessId, slug])
}

/// Milestone 4: durable, reviewable image BRIEFS (specifications only — never
/// generated images) derived from the approved sitemap + website copy artifact.
/// Strictly gated: requires an approved sitemap AND an existing copy artifact.
model WebsiteImageBrief {
  id               String  @id @default(cuid())
  businessId       String
  websiteProjectId String?
  sitemapId        String
  // Stable pointer to the copy artifact the briefs were derived from.
  copyArtifactId   String

  // status: draft | ready_for_review | approved | revision_requested |
  //         failed | archived
  status String @default("draft")

  // Full WebsiteImageBriefArtifact JSON (per-page hero + section briefs).
  imageBriefJson Json

  pageCount  Int @default(0)
  briefCount Int @default(0)

  generatedByUserId String?
  // source: copy_gate (default generation path) | manual | diagnostic
  source            String  @default("copy_gate")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project  WebsiteProject? @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([sitemapId])
}

// ── Milestone 5 — Generated website image assets (behind approved briefs) ──
// One row per generated (or diagnostic/failed) image asset produced from an
// APPROVED image brief. Durable R2 bucket/key are stored (never a signed URL);
// display URLs are resolved on demand from the R2 key. Hero assets carry QA
// scores. NO static build / publish / deploy is ever performed by this model.
model WebsiteGeneratedImageAsset {
  id               String  @id @default(cuid())
  businessId       String
  websiteProjectId String?
  sitemapId        String
  copyArtifactId   String
  // The brief SET this asset was generated from + the individual brief.
  imageBriefSetId  String
  imageBriefId     String

  pageSlug    String
  sectionName String
  // sectionType: hero | section
  sectionType String
  // assetRole: hero_image | section_image | supporting_image
  assetRole   String @default("hero_image")

  // status: queued | generating | generated | qa_failed | ready_for_review |
  //         approved | rejected | failed | archived
  status String @default("queued")

  // Provenance of the render (delegated to Tombstone Don/Andy pipeline).
  provider String?
  model    String?

  // Durable R2 reference (NEVER a signed URL). Display URLs resolve from key.
  r2Bucket String?
  r2Key    String?
  mimeType String?
  width    Int?
  height   Int?

  altText         String?
  promptSummary   String?
  visualRationale String?

  // Hero QA scores (0-100). Null for non-hero unless scored.
  qualityScore         Int?
  brandFitScore        Int?
  mobileSafeScore      Int?
  textReadabilityScore Int?
  focalPointScore      Int?
  // qaStatus: pending | passed | failed | skipped
  qaStatus             String?
  requiredFixesJson    Json?

  generatedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  project  WebsiteProject? @relation(fields: [websiteProjectId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([websiteProjectId])
  @@index([sitemapId])
  @@index([imageBriefSetId])
  @@index([imageBriefId])
  @@index([businessId, pageSlug])
}
