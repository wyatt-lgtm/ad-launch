// ══════════════════════════════════════════════════════════════════════════════
// Shared Asset Library
// ══════════════════════════════════════════════════════════════════════════════

model SharedAsset {
  id               String   @id @default(cuid())
  uploadedByUserId String
  // Scope: global, industry, brand_oem, franchise, licensed_stock, template
  scope            String   @default("global")
  // Category: industry_generic, licensed_stock, brand_oem, franchise, templates, video_clips, audio_clips, icons_graphics, educational_explainers, compliance_templates
  category         String
  assetType        String // logo, photo, video, audio, icon, graphic, template, document, font, color_palette
  title            String
  description      String   @default("")
  tags             String[] @default([])
  originalFilename String
  mimeType         String
  fileSizeBytes    Int
  width            Int? // pixels for images
  height           Int? // pixels for images
  duration         Float? // seconds for video/audio
  sha256Hash       String? // deduplication
  cloudStoragePath String
  publicUrl        String?
  thumbnailPath    String?
  thumbnailUrl     String?
  isPublic         Boolean  @default(false)

  // License / Rights
  licenseType           String    @default("owned") // owned, royalty_free, rights_managed, creative_commons, editorial_only, custom
  licenseStatus         String    @default("active") // active, expired, revoked, pending_renewal
  licenseExpiry         DateTime?
  licenseNotes          String?
  rightsHolder          String? // e.g. "Getty Images", "Shutterstock", "OEM Brand X"
  attributionRequired   Boolean   @default(false)
  attributionText       String?
  // Permission matrix flags
  allowWebsite          Boolean   @default(true)
  allowSocial           Boolean   @default(true)
  allowAds              Boolean   @default(true)
  allowEmail            Boolean   @default(true)
  allowPrint            Boolean   @default(true)
  allowVideo            Boolean   @default(true)
  allowInternal         Boolean   @default(true)
  allowAI               Boolean   @default(true)
  requiresApproval      Boolean   @default(false) // brand_oem default true
  maxResolution         String? // e.g. "1920x1080"
  noDerivatives         Boolean   @default(false)
  noCommercial          Boolean   @default(false)
  geographicRestriction String? // e.g. "US_only", "north_america"
  industryRestriction   String[]  @default([]) // restrict to specific industries
  // Targeting
  targetIndustries      String[]  @default([])
  targetBusinessTypes   String[]  @default([])
  // Status
  approvalStatus        String    @default("approved") // approved, pending_review, deprecated, archived
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  archivedAt            DateTime?

  uploadedBy   User                          @relation("SharedAssetUploader", fields: [uploadedByUserId], references: [id])
  assetContext AssetContext?
  packItems    SharedAssetPackItem[]
  approvals    BusinessSharedAssetApproval[]
  auditLogs    SharedAssetAuditLog[]

  @@index([scope])
  @@index([category])
  @@index([scope, category])
  @@index([sha256Hash])
  @@index([licenseStatus])
  @@index([approvalStatus])
  @@index([uploadedByUserId])
}

